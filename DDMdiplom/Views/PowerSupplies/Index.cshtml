@model IEnumerable<DDMdiplom.Models.PowerSupply>

@{
    ViewData["Title"] = "Блоки питания";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ========== Карточки блоков питания ========== */
        .psu-card {
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
        }
        .psu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        }
        .card-img-container {
            height: 220px;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }
        .card-img-top {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
        }
        .psu-card:hover .card-img-top {
            transform: scale(1.02);
        }
        .card-body {
            padding: 12px 12px 4px 12px;
        }
        .card-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.3;
        }
        .spec-badge {
            background: #f1f3f5;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 0.75rem;
            color: #495057;
            display: inline-block;
            white-space: nowrap;
        }
        .card-specs {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 10px;
        }
        .price {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e2a3e;
            white-space: nowrap;
        }
        .btn-outline-add {
            border-radius: 40px;
            padding: 5px 14px;
            font-size: 0.8rem;
            white-space: nowrap;
        }
        .card-footer {
            padding: 0 12px 14px 12px;
            background: transparent;
            border: none;
        }
        .card-footer .d-flex {
            gap: 8px;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }
        .psu-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 24px;
        }
        .psu-grid .col {
            flex: 0 0 280px;
            max-width: 280px;
        }

        /* Модальное окно */
        .modal-specs-table { width: 100%; margin-bottom: 20px; }
        .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
        .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
        .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
        .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
    </style>
}

<div class="container">
    <h1 class="mb-3">Блоки питания</h1>
    
    <!-- Переключатель совместимости -->
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <div class="psu-grid">
        @foreach (var psu in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(psu.ImageUrl) ? psu.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card psu-card h-100" data-id="@psu.Id"
                     data-max-power="@psu.MaximumPower"
                     data-psu-length="@psu.MaxPsuLength">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@psu.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@psu.Brand @psu.Model</h5>
                        <div class="card-specs">
                            @if (!string.IsNullOrEmpty(psu.Type))
                            {
                                <span class="spec-badge"><i class="bi bi-puzzle"></i> @psu.Type</span>
                            }
                            @if (!string.IsNullOrEmpty(psu.EnergyEfficient))
                            {
                                <span class="spec-badge"><i class="bi bi-award"></i> @psu.EnergyEfficient</span>
                            }
                            @if (psu.MaximumPower.HasValue)
                            {
                                <span class="spec-badge"><i class="bi bi-lightning-charge"></i> @psu.MaximumPower.Value Вт</span>
                            }
                            @if (!string.IsNullOrEmpty(psu.Modular))
                            {
                                <span class="spec-badge"><i class="bi bi-box"></i> @psu.Modular</span>
                            }
                            @if (psu.MaxPsuLength.HasValue)
                            {
                                <span class="spec-badge"><i class="bi bi-rulers"></i> @psu.MaxPsuLength.Value мм</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", psu.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@psu.Id"
                                    data-name="@psu.Brand @psu.Model"
                                    data-price="@psu.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Блок питания">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно для деталей блока питания -->
<div class="modal fade" id="psuModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // Обработчики для кнопок "Выбрать"
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: 0,
                    imageUrl: this.dataset.image
                };
                if (typeof addToBuild === 'function') {
                    addToBuild(component);
                } else {
                    console.error('addToBuild not defined');
                }
            });
        });

        // Открытие модального окна по клику на карточку (без изменений)
        document.querySelectorAll('.psu-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const psuId = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const response = await fetch(`/PowerSupplies/GetPowerSupply/${psuId}`);
                    const psu = await response.json();

                    let part1Rows = '';
                    if (psu.brand) part1Rows += `<tr><td>Бренд</td><td>${psu.brand}</td></tr>`;
                    if (psu.series) part1Rows += `<tr><td>Серия</td><td>${psu.series}</td></tr>`;
                    if (psu.model) part1Rows += `<tr><td>Модель</td><td>${psu.model}</td></tr>`;
                    if (psu.partNumber) part1Rows += `<tr><td>Парт-номер</td><td>${psu.partNumber}</td></tr>`;
                    if (psu.color) part1Rows += `<tr><td>Цвет</td><td>${psu.color}</td></tr>`;
                    if (psu.type) part1Rows += `<tr><td>Тип</td><td>${psu.type}</td></tr>`;
                    if (psu.maximumPower) part1Rows += `<tr><td>Макс. мощность</td><td>${psu.maximumPower} Вт</td></tr>`;
                    if (psu.modular) part1Rows += `<tr><td>Модульность</td><td>${psu.modular}</td></tr>`;
                    if (psu.energyEfficient) part1Rows += `<tr><td>Сертификат эффективности</td><td>${psu.energyEfficient}</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    let part2Rows = '';
                    if (psu.fans) part2Rows += `<tr><td>Вентилятор(ы)</td><td>${psu.fans}</td></tr>`;
                    if (psu.mainConnector) part2Rows += `<tr><td>Основной разъём</td><td>${psu.mainConnector}</td></tr>`;
                    if (psu.maxPsuLength) part2Rows += `<tr><td>Длина (мм)</td><td>${psu.maxPsuLength}</td></tr>`;
                    if (psu.inputVoltage) part2Rows += `<tr><td>Входное напряжение</td><td>${psu.inputVoltage}</td></tr>`;
                    if (psu.inputFrequencyRange) part2Rows += `<tr><td>Частотный диапазон</td><td>${psu.inputFrequencyRange}</td></tr>`;
                    if (psu.inputCurrent) part2Rows += `<tr><td>Входной ток</td><td>${psu.inputCurrent}</td></tr>`;
                    if (psu.connectors) part2Rows += `<tr><td>Разъёмы</td><td>${psu.connectors}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${psu.brand} ${psu.model}`;
                    const imageUrl = psu.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${psu.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${psu.id}" data-name="${title}" data-price="${psu.price}" data-tdp="0" data-image="${imageUrl}" data-type="Блок питания"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                                <h5 class="mb-0">${title}</h5>
                            </div>
                            <div class="text-end">
                                ${priceHtml}
                                ${selectBtn}
                            </div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: 0,
                            imageUrl: this.dataset.image
                        };
                        if (typeof addToBuild === 'function') addToBuild(component);
                    });

                    const modal = new bootstrap.Modal(document.getElementById('psuModal'));
                    modal.show();
                } catch (error) {
                    console.error(error);
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== ФИЛЬТР СОВМЕСТИМОСТИ БП ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const psuCards = document.querySelectorAll('.psu-card');

        async function applyPsuFilter() {
            if (!compatibilitySwitch.checked) {
                psuCards.forEach(card => card.closest('.col').style.display = '');
                return;
            }

            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                // Суммарный TDP (учитываем Tdp у процессора, видеокарты, возможно других)
                let totalTdp = 0;
                build.forEach(c => {
                    if (c.tdp) totalTdp += c.tdp;
                });
                const requiredPower = totalTdp + 200;

                // Ограничение по длине из корпуса
                const pcCase = build.find(c => c.type === "Корпус");
                const maxCasePsuLength = pcCase?.maxPsuLength;  // целое число или null

                psuCards.forEach(card => {
                    const col = card.closest('.col');
                    const psuPower = parseInt(card.dataset.maxPower) || 0;
                    const psuLength = parseInt(card.dataset.psuLength) || 0;

                    let visible = true;

                    // Фильтр по мощности
                    if (psuPower < requiredPower) {
                        visible = false;
                    }

                    // Фильтр по длине (если корпус выбран и указана макс. длина)
                    if (visible && pcCase && maxCasePsuLength && psuLength > maxCasePsuLength) {
                        visible = false;
                    }

                    col.style.display = visible ? '' : 'none';
                });
            } catch (error) {
                console.error('Ошибка фильтра БП:', error);
                psuCards.forEach(card => card.closest('.col').style.display = '');
            }
        }

        compatibilitySwitch.addEventListener('change', applyPsuFilter);
        applyPsuFilter();
    </script>
}