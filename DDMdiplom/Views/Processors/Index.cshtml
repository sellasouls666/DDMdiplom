@model IEnumerable<DDMdiplom.Models.Processor>

@{
    ViewData["Title"] = "Процессоры";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ========== Карточки процессоров ========== */
        .processor-card { border-radius: 20px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; height: 100%; cursor: pointer; width: 100%; max-width: 280px; margin: 0 auto; display: flex; flex-direction: column; }
        .processor-card:hover { transform: translateY(-5px); box-shadow: 0 12px 24px rgba(0,0,0,0.1); }
        .card-img-container { height: 220px; background: #f8f9fa; display: flex; align-items: center; justify-content: center; padding: 8px; }
        .card-img-top { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
        .processor-card:hover .card-img-top { transform: scale(1.02); }
        .card-body { padding: 12px 12px 4px 12px; }
        .card-title { font-size: 1rem; font-weight: 600; margin-bottom: 10px; line-height: 1.3; }
        .spec-badge { background: #f1f3f5; padding: 4px 8px; border-radius: 8px; font-size: 0.75rem; color: #495057; display: inline-block; white-space: nowrap; }
        .card-specs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
        .price { font-size: 1.25rem; font-weight: 700; color: #1e2a3e; white-space: nowrap; }
        .btn-outline-add { border-radius: 40px; padding: 5px 14px; font-size: 0.8rem; white-space: nowrap; }
        .card-footer { padding: 0 12px 14px 12px; background: transparent; border: none; }
        .card-footer .d-flex { gap: 8px; flex-wrap: wrap; justify-content: space-between; align-items: center; }
        .processors-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 24px;
        }
        .processors-grid .col { flex: 0 0 280px; max-width: 280px; }

        /* ========== Стили для боковой панели (перенесены сюда, но могут быть вынесены в глобальный CSS) ========== */
        .build-sidebar {
            position: fixed;
            top: 80px;
            right: 0;
            height: calc(100% - 80px);
            background: white;
            box-shadow: -2px 0 12px rgba(0,0,0,0.1);
            transition: width 0.3s ease;
            z-index: 1050;
            font-family: 'Segoe UI', Roboto, sans-serif;
            overflow: visible;
        }
        .build-sidebar.collapsed { width: 240px; }
        .build-sidebar.expanded { width: 400px; }

        .sidebar-toggle {
            position: absolute;
            left: -18px;
            top: 50%;
            transform: translateY(-50%);
            width: 32px;
            height: 32px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 1061;
            border: 1px solid #dee2e6;
            font-size: 1.2rem;
            color: #000;
        }

        .expanded-content {
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 20px 16px;
        }
        .collapsed-content {
            display: flex;
            flex-direction: column;
            padding: 16px 12px;
            height: 100%;
        }
        .expanded-content,
        .collapsed-content {
            height: 100%;
            overflow-y: auto;
        }
        .build-sidebar.collapsed .expanded-content { display: none; }
        .build-sidebar.expanded .collapsed-content { display: none; }

        .sidebar-header {
            flex-shrink: 0;
            border-bottom: 1px solid #dee2e6;
            margin-bottom: 16px;
            padding-bottom: 12px;
        }
        .build-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 12px; }

        .sidebar-components {
            flex: 1;
            overflow-y: auto;
            margin-bottom: 16px;
            padding-right: 4px;
        }
        .component-item {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
            padding: 8px;
            border-radius: 12px;
            background: #f8f9fa;
            transition: background 0.2s;
            cursor: pointer;
        }
        .component-item:hover { background: #e9ecef; }
        .component-icon { width: 40px; text-align: center; font-size: 1.5rem; color: #495057; }
        .component-details { flex: 1; }
        .component-name { font-weight: 500; font-size: 0.85rem; margin-bottom: 2px; }
        .component-price { font-size: 0.75rem; color: #1e2a3e; font-weight: 600; }
        .delete-component { color: #dc3545; background: none; border: none; padding: 0; font-size: 1.2rem; cursor: pointer; }
        .select-component-sidebar { border: 1px solid #ced4da; background: white; border-radius: 20px; padding: 2px 10px; font-size: 0.7rem; font-weight: 500; }
        .component-img { width: 35px; height: 35px; object-fit: contain; border-radius: 6px; }

        .sidebar-footer {
            flex-shrink: 0;
            border-top: 1px solid #dee2e6;
            padding-top: 12px;
        }
        .total-stats {
            background: #f1f3f5;
            border-radius: 12px;
            padding: 12px;
            margin: 8px 0;
        }
        .total-stats div { display: flex; justify-content: space-between; margin-bottom: 6px; }
        .btn-sidebar { border-radius: 30px; padding: 6px 12px; font-size: 0.8rem; width: 100%; margin-bottom: 8px; }

        .collapsed-header {
            text-align: center;
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid #dee2e6;
        }
        .collapsed-stats {
            text-align: center;
            font-size: 0.85rem;
            font-weight: 600;
            background: #f1f3f5;
            border-radius: 16px;
            padding: 8px 12px;
            margin-bottom: 12px;
        }
        .collapsed-stats div {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            margin: 4px 0;
        }
        .collapsed-stats div span:first-child {
            font-weight: normal;
        }
        .collapsed-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
            overflow-y: auto;
            flex: 1;
            padding: 4px 8px 8px 8px;
            margin-top: 8px;
        }
        .collapsed-category {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            cursor: pointer;
            padding: 8px 4px;
            border-radius: 16px;
            transition: background 0.2s;
        }
        .collapsed-category:hover { background: #f1f3f5; }
        .collapsed-category-icon {
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border-radius: 20px;
            margin-bottom: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            border: 1px solid #e9ecef;
        }
        .collapsed-category-icon img {
            max-width: 68px;
            max-height: 68px;
            object-fit: contain;
        }
        .collapsed-category-icon i {
            font-size: 3rem;
            color: #495057;
        }
        .collapsed-category-label {
            font-size: 0.75rem;
            font-weight: 500;
            max-width: 100px;
        }

        body.sidebar-expanded .container { margin-right: 400px; transition: margin-right 0.3s; }
        body.sidebar-collapsed .container { margin-right: 200px; transition: margin-right 0.3s; }

        .modal-specs-table { width: 100%; margin-bottom: 20px; }
        .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
        .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
        .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
        .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
        html, body { overflow-x: visible; }

        .total-stats div {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .value-group {
            display: inline-flex;
            gap: 4px;
        }
        .collapsed-stats div {
            font-weight: 700 !important;
        }
        .collapsed-stats div span:first-child {
            font-weight: 700 !important;
        }
        .collapsed-stats div span:last-child {
            font-weight: 700 !important;
        }
        .total-stats .value-group span:last-child {
            font-weight: 700 !important;
        }
    </style>
}

<div class="container">
    <h1 class="mb-3">Процессоры</h1>
    
    <!-- Переключатель под заголовком -->
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <!-- Сетка карточек как обычно -->
    <div class="processors-grid">
        @foreach (var proc in Model)
        {
            var memoryTypes = proc.MemoryTypes ?? "";
            var lastMemory = memoryTypes.Contains('/') ? memoryTypes.Split('/').Last().Trim() : memoryTypes;
            var imageUrl = !string.IsNullOrEmpty(proc.ImageUrl) ? proc.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card processor-card h-100"
                     data-id="@proc.Id"
                     data-socket="@proc.CpuSocketType"
                     data-memory-types="@proc.MemoryTypes">
                    <!-- содержимое карточки без изменений -->
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@proc.Name">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@proc.Brand @proc.Name</h5>
                        <div class="card-specs">
                            <span class="spec-badge"><i class="bi bi-cpu"></i> @proc.Cores ядер</span>
                            <span class="spec-badge"><i class="bi bi-speedometer2"></i> @proc.OperatingFrequency GHz</span>
                            <span class="spec-badge"><i class="bi bi-memory"></i> @lastMemory</span>
                            <span class="spec-badge"><i class="bi bi-lightning-charge"></i> @proc.ThermalDesignPower Вт</span>
                            <span class="spec-badge"><i class="bi bi-display"></i> @(string.IsNullOrEmpty(proc.IntegratedGraphics) ? "Нет" : proc.IntegratedGraphics)</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", proc.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@proc.Id"
                                    data-name="@proc.Brand @proc.Name"
                                    data-price="@proc.Price"
                                    data-tdp="@proc.ThermalDesignPower"
                                    data-image="@imageUrl"
                                    data-type="Процессор">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<!-- Модальное окно для деталей процессора -->
<div class="modal fade" id="processorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Подключаем общую боковую панель -->
@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // === Глобальная функция addToBuild уже доступна из _BuildSidebar ===

        // Обработчики кнопок "Выбрать"
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: parseInt(this.dataset.tdp) || 0,
                    imageUrl: this.dataset.image
                };
                if (typeof addToBuild === 'function') {
                    addToBuild(component);
                } else {
                    console.error('addToBuild not defined');
                }
            });
        });

        // Открытие модального окна с деталями процессора (без изменений)
        document.querySelectorAll('.processor-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const processorId = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const response = await fetch(`/Processors/GetProcessor/${processorId}`);
                    const processor = await response.json();

                    let part1Rows = '';
                    if (processor.brand) part1Rows += `<tr><td>Бренд</td><td>${processor.brand}</td></tr>`;
                    if (processor.processorsType) part1Rows += `<tr><td>Тип процессора</td><td>${processor.processorsType}</td></tr>`;
                    if (processor.series) part1Rows += `<tr><td>Серия</td><td>${processor.series}</td></tr>`;
                    if (processor.name) part1Rows += `<tr><td>Название</td><td>${processor.name}</td></tr>`;
                    if (processor.model) part1Rows += `<tr><td>Модель</td><td>${processor.model}</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    let part2Rows = '';
                    if (processor.cpuSocketType) part2Rows += `<tr><td>Сокет CPU</td><td>${processor.cpuSocketType}</td></tr>`;
                    if (processor.coreName) part2Rows += `<tr><td>Кодовое имя</td><td>${processor.coreName}</td></tr>`;
                    if (processor.cores) part2Rows += `<tr><td>Количество ядер</td><td>${processor.cores}</td></tr>`;
                    if (processor.threads) part2Rows += `<tr><td>Количество потоков</td><td>${processor.threads}</td></tr>`;
                    if (processor.operatingFrequency) part2Rows += `<tr><td>Базовая частота</td><td>${processor.operatingFrequency} GHz</td></tr>`;
                    if (processor.maxTurboFrequency) part2Rows += `<tr><td>Макс. турбо частота</td><td>${processor.maxTurboFrequency} GHz</td></tr>`;
                    if (processor.l1Cache) part2Rows += `<tr><td>L1 кэш</td><td>${processor.l1Cache}</td></tr>`;
                    if (processor.l2Cache) part2Rows += `<tr><td>L2 кэш</td><td>${processor.l2Cache}</td></tr>`;
                    if (processor.l3Cache) part2Rows += `<tr><td>L3 кэш</td><td>${processor.l3Cache}</td></tr>`;
                    if (processor.manufacturingTech) part2Rows += `<tr><td>Техпроцесс</td><td>${processor.manufacturingTech}</td></tr>`;
                    if (processor.instructionSet) part2Rows += `<tr><td>Набор инструкций</td><td>${processor.instructionSet}</td></tr>`;
                    if (processor.memoryTypes) part2Rows += `<tr><td>Типы памяти</td><td>${processor.memoryTypes}</td></tr>`;
                    if (processor.memoryChannel) part2Rows += `<tr><td>Каналов памяти</td><td>${processor.memoryChannel}</td></tr>`;
                    if (processor.maxMemorySize) part2Rows += `<tr><td>Макс. объем памяти</td><td>${processor.maxMemorySize}</td></tr>`;
                    if (processor.integratedGraphics) part2Rows += `<tr><td>Встроенная графика</td><td>${processor.integratedGraphics}</td></tr>`;
                    if (processor.graphicsBaseFrequency) part2Rows += `<tr><td>Частота графики</td><td>${processor.graphicsBaseFrequency} MHz</td></tr>`;
                    if (processor.pciExpressRevision) part2Rows += `<tr><td>Версия PCIe</td><td>${processor.pciExpressRevision}</td></tr>`;
                    if (processor.maxPciExpressLanes) part2Rows += `<tr><td>Макс. линий PCIe</td><td>${processor.maxPciExpressLanes}</td></tr>`;
                    if (processor.thermalDesignPower) part2Rows += `<tr><td>TDP</td><td>${processor.thermalDesignPower} Вт</td></tr>`;
                    if (processor.coolingDevice) part2Rows += `<tr><td>Охлаждение</td><td>${processor.coolingDevice}</td></tr>`;
                    if (processor.compatibleChipsets) part2Rows += `<tr><td>Совместимые чипсеты</td><td>${processor.compatibleChipsets}</td></tr>`;
                    if (processor.supportedOperatingSystems) part2Rows += `<tr><td>Поддерживаемые ОС</td><td>${processor.supportedOperatingSystems}</td></tr>`;
                    if (processor.advancedTechnologies) part2Rows += `<tr><td>Технологии</td><td>${processor.advancedTechnologies}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${processor.brand} ${processor.name}`;
                    const imageUrl = processor.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${processor.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${processor.id}" data-name="${title}" data-price="${processor.price}" data-tdp="${processor.thermalDesignPower}" data-image="${imageUrl}" data-type="Процессор"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                                <h5 class="mb-0">${title}</h5>
                            </div>
                            <div class="text-end">
                                ${priceHtml}
                                ${selectBtn}
                            </div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: parseInt(this.dataset.tdp) || 0,
                            imageUrl: this.dataset.image
                        };
                        if (typeof addToBuild === 'function') addToBuild(component);
                    });

                    const modal = new bootstrap.Modal(document.getElementById('processorModal'));
                    modal.show();
                } catch (error) {
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== НОВАЯ ЛОГИКА ФИЛЬТРАЦИИ ПО СОВМЕСТИМОСТИ ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const processorCards = document.querySelectorAll('.processor-card');

        // Функция извлечения типа памяти из строки Speed (например "DDR5 6400")
        function extractMemoryType(memorySpeed) {
            if (!memorySpeed) return null;
            const match = memorySpeed.match(/DDR\d+/i);
            return match ? match[0].toUpperCase() : null;
        }

        async function applyCompatibilityFilter() {
            if (!compatibilitySwitch.checked) {
                // Показать все карточки
                processorCards.forEach(card => {
                    card.closest('.col').style.display = '';
                });
                return;
            }

            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                // Извлекаем компоненты
                const motherboard = build.find(c => c.type === "Материнская плата");
                const memoryModules = build.filter(c => c.type === "Оперативная память");
                const cpuCooler = build.find(c => c.type === "Система охлаждения");

                // Собираем условия
                const socketRequired = motherboard?.cpuSocketType;  // теперь доступно
                let memoryTypesRequired = [];
                if (memoryModules.length > 0) {
                    memoryTypesRequired = memoryModules.map(m => extractMemoryType(m.speed)).filter(Boolean);
                }
                let coolerSocketRequired = null;
                if (cpuCooler) {
                    if (cpuCooler.cpuSocketCompatibility) {
                        coolerSocketRequired = cpuCooler.cpuSocketCompatibility;
                    } else if (cpuCooler.blockCompatibility) {
                        coolerSocketRequired = cpuCooler.blockCompatibility;
                    }
                }

                // Фильтруем карточки
                processorCards.forEach(card => {
                    const col = card.closest('.col');
                    const processorSocket = card.dataset.socket || '';
                    const processorMemoryTypes = (card.dataset.memoryTypes || '').toUpperCase();

                    let visible = true;

                    // Проверка сокета материнской платы
                    if (socketRequired && processorSocket && !processorSocket.includes(socketRequired)) {
                        visible = false;
                    }

                    // Проверка типов памяти (если выбраны модули памяти)
                    if (visible && memoryTypesRequired.length > 0) {
                        // Процессор должен поддерживать хотя бы один из требуемых типов
                        const supportsMemory = memoryTypesRequired.some(memType =>
                            processorMemoryTypes.includes(memType)
                        );
                        if (!supportsMemory) visible = false;
                    }

                    // Проверка совместимости с охлаждением
                    if (visible && coolerSocketRequired) {
                        // Проверяем, содержит ли строка совместимости кулера сокет процессора
                        if (!coolerSocketRequired.includes(processorSocket)) {
                            visible = false;
                        }
                    }

                    col.style.display = visible ? '' : 'none';
                });
            } catch (error) {
                console.error('Ошибка при получении сборки:', error);
                // В случае ошибки показываем все
                processorCards.forEach(card => {
                    card.closest('.col').style.display = '';
                });
            }
        }

        // Обработчик переключения
        compatibilitySwitch.addEventListener('change', applyCompatibilityFilter);
        // Применить фильтр сразу при загрузке (переключатель включен по умолчанию)
        applyCompatibilityFilter();
    </script>
}