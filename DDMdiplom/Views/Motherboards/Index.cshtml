@model IEnumerable<DDMdiplom.Models.Motherboard>

@{
    ViewData["Title"] = "Материнские платы";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    /* ========== Карточки материнских плат ========== */
    .motherboard-card {
        border-radius: 20px;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
        cursor: pointer;
        width: 100%;
        max-width: 280px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
    }
    .motherboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }
    .card-img-container {
        height: 220px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px;
    }
    .card-img-top {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
    }
    .motherboard-card:hover .card-img-top {
        transform: scale(1.02);
    }
    .card-body {
        padding: 12px 12px 4px 12px;
    }
    .card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 10px;
        line-height: 1.3;
    }
    .spec-badge {
        background: #f1f3f5;
        padding: 4px 8px;
        border-radius: 8px;
        font-size: 0.75rem;
        color: #495057;
        display: inline-block;
        white-space: nowrap;
    }
    .card-specs {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 10px;
    }
    .price {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e2a3e;
        white-space: nowrap;
    }
    .btn-outline-add {
        border-radius: 40px;
        padding: 5px 14px;
        font-size: 0.8rem;
        white-space: nowrap;
    }
    .card-footer {
        padding: 0 12px 14px 12px;
        background: transparent;
        border: none;
    }
    .card-footer .d-flex {
        gap: 8px;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
    }
    .motherboards-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 24px;
    }
    .motherboards-grid .col {
        flex: 0 0 280px;
        max-width: 280px;
    }

    /* ========== Боковая панель (та же, что и для других страниц) ========== */
    .build-sidebar {
        position: fixed;
        top: 80px;
        right: 0;
        height: calc(100% - 80px);
        background: white;
        box-shadow: -2px 0 12px rgba(0,0,0,0.1);
        transition: width 0.3s ease;
        z-index: 1050;
        font-family: 'Segoe UI', Roboto, sans-serif;
        overflow: visible;
    }
    .build-sidebar.collapsed { width: 240px; }
    .build-sidebar.expanded { width: 400px; }

    .sidebar-toggle {
        position: absolute;
        left: -18px;
        top: 50%;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        background: white;
        border-radius: 50%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 1061;
        border: 1px solid #dee2e6;
        font-size: 1.2rem;
        color: #000;
    }

    .expanded-content {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 20px 16px;
    }
    .collapsed-content {
        display: flex;
        flex-direction: column;
        padding: 16px 12px;
        height: 100%;
    }

    .expanded-content,
    .collapsed-content {
        height: 100%;
        overflow-y: auto;
    }
    .build-sidebar.collapsed .expanded-content { display: none; }
    .build-sidebar.expanded .collapsed-content { display: none; }

    .sidebar-header {
        flex-shrink: 0;
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 16px;
        padding-bottom: 12px;
    }
    .build-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 12px; }

    .sidebar-components {
        flex: 1;
        overflow-y: auto;
        margin-bottom: 16px;
        padding-right: 4px;
    }
    .component-item {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        padding: 8px;
        border-radius: 12px;
        background: #f8f9fa;
        transition: background 0.2s;
        cursor: pointer;
    }
    .component-item:hover { background: #e9ecef; }
    .component-icon { width: 40px; text-align: center; font-size: 1.5rem; color: #495057; }
    .component-details { flex: 1; }
    .component-name { font-weight: 500; font-size: 0.85rem; margin-bottom: 2px; }
    .component-price { font-size: 0.75rem; color: #1e2a3e; font-weight: 600; }
    .delete-component { color: #dc3545; background: none; border: none; padding: 0; font-size: 1.2rem; cursor: pointer; }
    .select-component-sidebar { border: 1px solid #ced4da; background: white; border-radius: 20px; padding: 2px 10px; font-size: 0.7rem; font-weight: 500; }
    .component-img { width: 35px; height: 35px; object-fit: contain; border-radius: 6px; }

    .sidebar-footer {
        flex-shrink: 0;
        border-top: 1px solid #dee2e6;
        padding-top: 12px;
    }
    .total-stats {
        background: #f1f3f5;
        border-radius: 12px;
        padding: 12px;
        margin: 8px 0;
    }
    .total-stats div { display: flex; justify-content: space-between; margin-bottom: 6px; }
    .btn-sidebar { border-radius: 30px; padding: 6px 12px; font-size: 0.8rem; width: 100%; margin-bottom: 8px; }

    .collapsed-header {
        text-align: center;
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #dee2e6;
    }
    .collapsed-stats {
        text-align: center;
        font-size: 0.85rem;
        font-weight: 600;
        background: #f1f3f5;
        border-radius: 16px;
        padding: 8px 12px;
        margin-bottom: 12px;
    }
    .collapsed-stats div {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        margin: 4px 0;
    }
    .collapsed-stats div span:first-child {
        font-weight: normal;
    }
    .collapsed-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        overflow-y: auto;
        flex: 1;
        padding: 4px 8px 8px 8px;
        margin-top: 8px;
    }
    .collapsed-category {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        cursor: pointer;
        padding: 8px 4px;
        border-radius: 16px;
        transition: background 0.2s;
    }
    .collapsed-category:hover { background: #f1f3f5; }
    .collapsed-category-icon {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 20px;
        margin-bottom: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }
    .collapsed-category-icon img {
        max-width: 68px;
        max-height: 68px;
        object-fit: contain;
    }
    .collapsed-category-icon i {
        font-size: 3rem;
        color: #495057;
    }
    .collapsed-category-label {
        font-size: 0.75rem;
        font-weight: 500;
        max-width: 100px;
    }

    body.sidebar-expanded .container { margin-right: 400px; transition: margin-right 0.3s; }
    body.sidebar-collapsed .container { margin-right: 200px; transition: margin-right 0.3s; }

    .modal-specs-table { width: 100%; margin-bottom: 20px; }
    .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
    .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
    .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
    .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
    html, body { overflow-x: visible; }

    .total-stats div {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .value-group {
        display: inline-flex;
        gap: 4px;
    }

    .collapsed-stats div {
        font-weight: 700 !important;
    }
    .collapsed-stats div span:first-child {
        font-weight: 700 !important;
    }
    .collapsed-stats div span:last-child {
        font-weight: 700 !important;
    }
    .total-stats .value-group span:last-child {
        font-weight: 700 !important;
    }
</style>
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Материнские платы</h1>
    </div>

    <div class="motherboards-grid">
        @foreach (var mb in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(mb.ImageUrl) ? mb.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card motherboard-card h-100" data-id="@mb.Id">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@mb.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@mb.Brand @mb.Model</h5>
                        <div class="card-specs">
                            <span class="spec-badge"><i class="bi bi-cpu"></i> @mb.CpuSocketType</span>
                            <span class="spec-badge"><i class="bi bi-pc-display"></i> @(string.IsNullOrEmpty(mb.FormFactor) ? "—" : mb.FormFactor)</span>
                            <span class="spec-badge"><i class="bi bi-memory"></i> @(mb.MaxMemorySize.HasValue ? mb.MaxMemorySize.Value.ToString() + " ГБ" : "—")</span>
                            <span class="spec-badge"><i class="bi bi-motherboard"></i> @mb.Chipset</span>
                            <span class="spec-badge"><i class="bi bi-layers"></i> 
                                @{
                                    var slots = mb.MemorySlots.HasValue ? mb.MemorySlots.Value.ToString() : "?";
                                    var memoryType = "";
                                    if (!string.IsNullOrEmpty(mb.MemoryStandard))
                                    {
                                        // Извлекаем тип DDR (DDR3, DDR4, DDR5 и т.д.)
                                        var match = System.Text.RegularExpressions.Regex.Match(mb.MemoryStandard, @"\bDDR\d+\b");
                                        if (match.Success)
                                            memoryType = match.Value;
                                    }
                                    var displayText = $"{slots} слота";
                                    if (!string.IsNullOrEmpty(memoryType))
                                        displayText += $" ({memoryType})";
                                }
                                @displayText
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", mb.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@mb.Id"
                                    data-name="@mb.Brand @mb.Model"
                                    data-price="@mb.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Материнская плата">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно -->
<div class="modal fade" id="motherboardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Боковая панель сборки -->
<div id="buildSidebar" class="build-sidebar collapsed">
    <div class="sidebar-toggle" id="sidebarToggle">
        <i class="bi bi-chevron-left"></i>
    </div>
    <div class="collapsed-content">
        <div class="collapsed-header">Конфигуратор ПК</div>
        <div class="collapsed-stats">
            <div><span id="collapsedPrice">0</span><span>₽</span></div>
            <div><span id="collapsedWatts">0</span><span>Вт</span></div>
        </div>
        <div id="collapsedCategoriesGrid" class="collapsed-grid"></div>
    </div>
    <div class="expanded-content">
        <div class="sidebar-header">
            <div class="build-title">Конфигуратор ПК</div>
            <label class="form-label small">Название сборки</label>
            <input type="text" id="buildName" class="form-control form-control-sm" placeholder="Моя сборка" value="Моя сборка">
        </div>
        <div class="sidebar-components" id="componentsList"></div>
        <div class="sidebar-footer">
            <div class="total-stats">
                <div><span>Количество компонентов:</span> <strong id="selectedCount">0</strong></div>
                <div><span>Суммарная мощность:</span> <span class="value-group"><strong id="totalWatts">0</strong> <span>Вт</span></span></div>
                <div><span>Общая цена:</span> <strong id="totalPriceSidebar">0</strong> ₽</div>
            </div>
            <button class="btn btn-outline-secondary btn-sidebar" id="resetBuildBtn">Сбросить сборку</button>
            <button class="btn btn-dark btn-sidebar" id="saveBuildBtn">Сохранить сборку</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    // Все категории
    const allCategories = [
        { type: "Процессор", icon: "bi-cpu", defaultName: "Процессор" },
        { type: "Видеокарта", icon: "bi-gpu-card", defaultName: "Видеокарта" },
        { type: "Материнская плата", icon: "bi-motherboard", defaultName: "Материнская плата" },
        { type: "Оперативная память", icon: "bi-memory", defaultName: "Оперативная память" },
        { type: "Накопитель", icon: "bi-hdd-stack", defaultName: "Накопитель" },
        { type: "Блок питания", icon: "bi-plug", defaultName: "Блок питания" },
        { type: "Корпус", icon: "bi-pc-display", defaultName: "Корпус" },
        { type: "Система охлаждения", icon: "bi-fan", defaultName: "Система охлаждения" },
        { type: "Операционная система", icon: "bi-windows", defaultName: "ОС" },
        { type: "Монитор", icon: "bi-display", defaultName: "Монитор" },
        { type: "Источник бесперебойного питания", icon: "bi-battery-charging", defaultName: "UPS" },
        { type: "Клавиатура", icon: "bi-keyboard", defaultName: "Клавиатура" },
        { type: "Мышь", icon: "bi-mouse", defaultName: "Мышь" }
    ];

    let currentBuild = [];

    function loadBuildFromSession() {
        fetch('/PcBuilder/GetBuild')
            .then(response => response.json())
            .then(data => {
                if (data.success && data.build) {
                    currentBuild = data.build;
                    renderAll();
                } else {
                    renderAll();
                }
            });
    }

    function renderAll() {
        renderSidebarExpanded();
        renderSidebarCollapsed();
    }

    function renderSidebarExpanded() {
        let totalPrice = 0, totalWatts = 0;
        currentBuild.forEach(item => {
            totalPrice += item.price;
            if (item.tdp) totalWatts += item.tdp;
        });
        document.getElementById('totalPriceSidebar').innerText = totalPrice.toLocaleString() + ' ₽';
        document.getElementById('totalWatts').innerText = totalWatts;
        document.getElementById('selectedCount').innerText = currentBuild.length;

        let html = '';
        allCategories.forEach(cat => {
            const selected = currentBuild.find(c => c.type === cat.type);
            if (selected) {
                html += `
                    <div class="component-item" data-type="${cat.type}">
                        <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                        <img src="${selected.imageUrl || '/images/placeholder.png'}" class="component-img">
                        <div class="component-details">
                            <div class="component-name">${selected.name}</div>
                            <div class="component-price">${selected.price.toLocaleString()} ₽</div>
                        </div>
                        <button class="delete-component" data-id="${selected.id}" title="Удалить"><i class="bi bi-trash"></i></button>
                    </div>
                `;
            } else {
                html += `
                    <div class="component-item" data-type="${cat.type}">
                        <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                        <div class="component-details">
                            <div class="component-name">${cat.defaultName}</div>
                            <div class="component-price">—</div>
                        </div>
                        <button class="btn btn-sm select-component-sidebar" data-type="${cat.type}">Выбрать</button>
                    </div>
                `;
            }
        });
        document.getElementById('componentsList').innerHTML = html;

        document.querySelectorAll('.delete-component').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = parseInt(btn.getAttribute('data-id'));
                removeFromBuild(id);
            });
        });
        document.querySelectorAll('.select-component-sidebar').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const type = btn.getAttribute('data-type');
                if (type === "Процессор") window.location.href = '/Processors';
                else if (type === "Видеокарта") window.location.href = '/GraphicsCards';
                else if (type === "Материнская плата") window.location.href = '/Motherboards';
                else alert(`Переход на страницу выбора ${type} (пока не реализовано)`);
            });
        });
        document.querySelectorAll('.component-item').forEach(row => {
            row.addEventListener('click', (e) => {
                if (e.target.closest('.delete-component')) return;
                if (e.target.closest('.select-component-sidebar')) return;
                const type = row.getAttribute('data-type');
                if (type === "Процессор") window.location.href = '/Processors';
                else if (type === "Видеокарта") window.location.href = '/GraphicsCards';
                else if (type === "Материнская плата") window.location.href = '/Motherboards';
                else if (type) alert(`Переход на страницу ${type} (пока не реализовано)`);
            });
        });
    }

    function renderSidebarCollapsed() {
        let totalPrice = 0, totalWatts = 0;
        currentBuild.forEach(item => {
            totalPrice += item.price;
            if (item.tdp) totalWatts += item.tdp;
        });
        document.getElementById('collapsedWatts').innerText = totalWatts;
        document.getElementById('collapsedPrice').innerText = totalPrice.toLocaleString();

        let gridHtml = '';
        allCategories.forEach((cat, idx) => {
            const selected = currentBuild.find(c => c.type === cat.type);
            let iconHtml = '';
            if (selected && selected.imageUrl) {
                iconHtml = `<img src="${selected.imageUrl}" alt="${selected.name}">`;
            } else {
                iconHtml = `<i class="bi ${cat.icon}"></i>`;
            }
            const label = selected ? selected.name : cat.defaultName;
            gridHtml += `
                <div class="collapsed-category" data-type="${cat.type}" data-index="${idx}">
                    <div class="collapsed-category-icon">${iconHtml}</div>
                    <div class="collapsed-category-label">${label.length > 20 ? label.substring(0,18)+'…' : label}</div>
                </div>
            `;
        });
        document.getElementById('collapsedCategoriesGrid').innerHTML = gridHtml;
        document.querySelectorAll('.collapsed-category').forEach(el => {
            el.addEventListener('click', () => {
                const type = el.getAttribute('data-type');
                if (type === "Процессор") window.location.href = '/Processors';
                else if (type === "Видеокарта") window.location.href = '/GraphicsCards';
                else if (type === "Материнская плата") window.location.href = '/Motherboards';
                else alert(`Переход на страницу выбора ${type} (пока не реализовано)`);
            });
        });
    }

    function addToBuild(id, name, price, type, tdp, imageUrl) {
        fetch('/PcBuilder/AddComponent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, name, price, type, tdp, imageUrl })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                currentBuild = data.build;
                renderAll();
            } else {
                alert('Ошибка добавления');
            }
        });
    }

    function removeFromBuild(id) {
        fetch('/PcBuilder/RemoveComponent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                currentBuild = data.build;
                renderAll();
            }
        });
    }

    // Кнопки "Выбрать" в карточках
    document.querySelectorAll('.select-component').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            addToBuild(
                parseInt(this.dataset.id),
                this.dataset.name,
                parseFloat(this.dataset.price),
                this.dataset.type,
                parseInt(this.dataset.tdp) || 0,
                this.dataset.image
            );
        });
    });

    // Открытие модального окна для материнской платы
    document.querySelectorAll('.motherboard-card').forEach(card => {
        card.addEventListener('click', async function(e) {
            if (e.target.closest('.select-component')) return;
            const mbId = this.getAttribute('data-id');
            const contentDiv = document.getElementById('modalContent');
            contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
            try {
                const response = await fetch(`/Motherboards/GetMotherboard/${mbId}`);
                const mb = await response.json();

                // Основная информация (только непустые поля)
                let part1Rows = '';
                if (mb.brand) part1Rows += `<tr><td>Бренд</td><td>${mb.brand}</td></td>`;
                if (mb.model) part1Rows += `<tr><td>Модель</td><td>${mb.model}</td></tr>`;
                if (mb.cpuSocketType) part1Rows += `<tr><td>Сокет CPU</td><td>${mb.cpuSocketType}</td></td>`;
                if (mb.cpuType) part1Rows += `<tr><td>Поддерживаемые CPU</td><td>${mb.cpuType}</td></tr>`;
                if (mb.chipset) part1Rows += `<tr><td>Чипсет</td><td>${mb.chipset}</td></tr>`;
                if (mb.formFactor) part1Rows += `<tr><td>Форм-фактор</td><td>${mb.formFactor}</td></tr>`;

                const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                // Детальные характеристики
                let part2Rows = '';
                if (mb.memorySlots) part2Rows += `<tr><td>Слотов памяти</td><td>${mb.memorySlots}</td></tr>`;
                if (mb.memoryStandard) part2Rows += `<tr><td>Стандарт памяти</td><td>${mb.memoryStandard}</td></tr>`;
                if (mb.maxMemorySize) part2Rows += `<tr><td>Макс. объём памяти (ГБ)</td><td>${mb.maxMemorySize}</td></tr>`;
                if (mb.eccSupported) part2Rows += `<tr><td>Поддержка ECC</td><td>${mb.eccSupported}</td></tr>`;
                if (mb.pciExpress50x16) part2Rows += `<tr><td>PCI Express 5.0 x16</td><td>${mb.pciExpress50x16}</td></tr>`;
                if (mb.pciExpressX4) part2Rows += `<tr><td>PCI Express x4</td><td>${mb.pciExpressX4}</td></tr>`;
                if (mb.pciExpressX1) part2Rows += `<tr><td>PCI Express x1</td><td>${mb.pciExpressX1}</td></tr>`;
                if (mb.sataPorts) part2Rows += `<tr><td>SATA порты</td><td>${mb.sataPorts}</td></tr>`;
                if (mb.m2Slots) part2Rows += `<tr><td>M.2 слоты</td><td>${mb.m2Slots}</td></tr>`;
                if (mb.audioChipset) part2Rows += `<tr><td>Аудио чипсет</td><td>${mb.audioChipset}</td></tr>`;
                if (mb.audioChannels) part2Rows += `<tr><td>Аудио каналы</td><td>${mb.audioChannels}</td></tr>`;
                if (mb.lanChipset) part2Rows += `<tr><td>LAN чипсет</td><td>${mb.lanChipset}</td></tr>`;
                if (mb.maxLanSpeed) part2Rows += `<tr><td>Скорость LAN (Мбит/с)</td><td>${mb.maxLanSpeed}</td></tr>`;
                if (mb.wirelessLan) part2Rows += `<tr><td>Wi-Fi</td><td>${mb.wirelessLan}</td></tr>`;
                if (mb.bluetooth) part2Rows += `<tr><td>Bluetooth</td><td>${mb.bluetooth}</td></tr>`;
                if (mb.rearPanelPorts) part2Rows += `<tr><td>Задние порты IO</td><td>${mb.rearPanelPorts}</td></tr>`;
                if (mb.internalIoConnectors) part2Rows += `<tr><td>Внутренние разъёмы IO</td><td>${mb.internalIoConnectors}</td></tr>`;
                if (mb.ledLighting) part2Rows += `<tr><td>Подсветка</td><td>${mb.ledLighting}</td></tr>`;
                if (mb.dimensions) part2Rows += `<tr><td>Размеры (Д x Ш, дюймы)</td><td>${mb.dimensions}</td></tr>`;
                if (mb.powerConnectors) part2Rows += `<tr><td>Разъёмы питания</td><td>${mb.powerConnectors}</td></tr>`;
                if (mb.biosFeature) part2Rows += `<tr><td>Особенности BIOS</td><td>${mb.biosFeature}</td></tr>`;
                if (mb.features) part2Rows += `<tr><td>Особенности</td><td>${mb.features}</td></tr>`;

                const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                const title = `${mb.brand} ${mb.model}`;
                const imageUrl = mb.imageUrl || '/images/placeholder.png';
                const priceHtml = `<div class="price-large mb-2">${mb.price.toLocaleString()} ₽</div>`;
                const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${mb.id}" data-name="${title}" data-price="${mb.price}" data-tdp="0" data-image="${imageUrl}" data-type="Материнская плата"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                contentDiv.innerHTML = `
                    <div class="d-flex justify-content-end mb-2">
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                            <h5 class="mb-0">${title}</h5>
                        </div>
                        <div class="text-end">
                            ${priceHtml}
                            ${selectBtn}
                        </div>
                    </div>
                    ${part1}
                    ${part2}
                `;

                document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                    e.stopPropagation();
                    addToBuild(
                        parseInt(this.dataset.id),
                        this.dataset.name,
                        parseFloat(this.dataset.price),
                        this.dataset.type,
                        parseInt(this.dataset.tdp) || 0,
                        this.dataset.image
                    );
                    bootstrap.Modal.getInstance(document.getElementById('motherboardModal')).hide();
                });

                const modal = new bootstrap.Modal(document.getElementById('motherboardModal'));
                modal.show();
            } catch (error) {
                contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
            }
        });
    });

    // Управление сворачиванием панели
    const sidebar = document.getElementById('buildSidebar');
    const toggleBtn = document.getElementById('sidebarToggle');
    const body = document.body;
    toggleBtn.addEventListener('click', () => {
        if (sidebar.classList.contains('collapsed')) {
            sidebar.classList.remove('collapsed');
            sidebar.classList.add('expanded');
            body.classList.remove('sidebar-collapsed');
            body.classList.add('sidebar-expanded');
            toggleBtn.innerHTML = '<i class="bi bi-chevron-right"></i>';
        } else {
            sidebar.classList.remove('expanded');
            sidebar.classList.add('collapsed');
            body.classList.remove('sidebar-expanded');
            body.classList.add('sidebar-collapsed');
            toggleBtn.innerHTML = '<i class="bi bi-chevron-left"></i>';
        }
    });
    body.classList.add('sidebar-collapsed');

    loadBuildFromSession();
    </script>
}