@model IEnumerable<DDMdiplom.Models.Motherboard>

@{
    ViewData["Title"] = "Материнские платы";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    /* ========== Карточки материнских плат ========== */
    .motherboard-card {
        border-radius: 20px;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
        cursor: pointer;
        width: 100%;
        max-width: 280px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
    }
    .motherboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }
    .card-img-container {
        height: 220px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px;
    }
    .card-img-top {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
    }
    .motherboard-card:hover .card-img-top {
        transform: scale(1.02);
    }
    .card-body {
        padding: 12px 12px 4px 12px;
    }
    .card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 10px;
        line-height: 1.3;
    }
    .spec-badge {
        background: #f1f3f5;
        padding: 4px 8px;
        border-radius: 8px;
        font-size: 0.75rem;
        color: #495057;
        display: inline-block;
        white-space: nowrap;
    }
    .card-specs {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 10px;
    }
    .price {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e2a3e;
        white-space: nowrap;
    }
    .btn-outline-add {
        border-radius: 40px;
        padding: 5px 14px;
        font-size: 0.8rem;
        white-space: nowrap;
    }
    .card-footer {
        padding: 0 12px 14px 12px;
        background: transparent;
        border: none;
    }
    .card-footer .d-flex {
        gap: 8px;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
    }
    .motherboards-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 24px;
    }
    .motherboards-grid .col {
        flex: 0 0 280px;
        max-width: 280px;
    }

    /* Стили для модального окна */
    .modal-specs-table { width: 100%; margin-bottom: 20px; }
    .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
    .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
    .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
    .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
</style>
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Материнские платы</h1>
    </div>

    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <div class="motherboards-grid">
        @foreach (var mb in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(mb.ImageUrl) ? mb.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card motherboard-card h-100"
                     data-id="@mb.Id"
                     data-socket="@mb.CpuSocketType"
                     data-memory-standard="@mb.MemoryStandard"
                     data-form-factor="@mb.FormFactor">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@mb.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@mb.Brand @mb.Model</h5>
                        <div class="card-specs">
                            <span class="spec-badge"><i class="bi bi-cpu"></i> @mb.CpuSocketType</span>
                            <span class="spec-badge"><i class="bi bi-pc-display"></i> @(string.IsNullOrEmpty(mb.FormFactor) ? "—" : mb.FormFactor)</span>
                            <span class="spec-badge"><i class="bi bi-memory"></i> @(mb.MaxMemorySize.HasValue ? mb.MaxMemorySize.Value.ToString() + " ГБ" : "—")</span>
                            <span class="spec-badge"><i class="bi bi-motherboard"></i> @mb.Chipset</span>
                            <span class="spec-badge"><i class="bi bi-layers"></i> 
                                @{
                                    var slots = mb.MemorySlots.HasValue ? mb.MemorySlots.Value.ToString() : "?";
                                    var memoryType = "";
                                    if (!string.IsNullOrEmpty(mb.MemoryStandard))
                                    {
                                        var match = System.Text.RegularExpressions.Regex.Match(mb.MemoryStandard, @"\bDDR\d+\b");
                                        if (match.Success)
                                            memoryType = match.Value;
                                    }
                                    var displayText = $"{slots} слота";
                                    if (!string.IsNullOrEmpty(memoryType))
                                        displayText += $" ({memoryType})";
                                }
                                @displayText
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", mb.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@mb.Id"
                                    data-name="@mb.Brand @mb.Model"
                                    data-price="@mb.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Материнская плата"
                                    data-memory-slots="@mb.MemorySlots">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно для материнской платы -->
<div class="modal fade" id="motherboardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Подключаем общую боковую панель -->
@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // Обработчики кнопок "Выбрать" в карточках
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: parseInt(this.dataset.tdp) || 0,
                    imageUrl: this.dataset.image,
                    memorySlots: this.dataset.memorySlots ? parseInt(this.dataset.memorySlots) : null
                };
                if (typeof addToBuild === 'function') {
                    addToBuild(component);
                } else {
                    console.error('addToBuild not defined');
                }
            });
        });

        // Открытие модального окна с деталями материнской платы
        document.querySelectorAll('.motherboard-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const mbId = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const response = await fetch(`/Motherboards/GetMotherboard/${mbId}`);
                    const mb = await response.json();

                    // Основная информация
                    let part1Rows = '';
                    if (mb.brand) part1Rows += `<tr><td>Бренд</td><td>${mb.brand}</td></tr>`;
                    if (mb.model) part1Rows += `<tr><td>Модель</td><td>${mb.model}</td></tr>`;
                    if (mb.cpuSocketType) part1Rows += `<tr><td>Сокет CPU</td><td>${mb.cpuSocketType}</td></tr>`;
                    if (mb.cpuType) part1Rows += `<tr><td>Поддерживаемые CPU</td><td>${mb.cpuType}</td></tr>`;
                    if (mb.chipset) part1Rows += `<tr><td>Чипсет</td><td>${mb.chipset}</td></tr>`;
                    if (mb.formFactor) part1Rows += `<tr><td>Форм-фактор</td><td>${mb.formFactor}</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    // Детальные характеристики
                    let part2Rows = '';
                    if (mb.memorySlots) part2Rows += `<tr><td>Слотов памяти</td><td>${mb.memorySlots}</td></tr>`;
                    if (mb.memoryStandard) part2Rows += `<tr><td>Стандарт памяти</td><td>${mb.memoryStandard}</td></tr>`;
                    if (mb.maxMemorySize) part2Rows += `<tr><td>Макс. объём памяти (ГБ)</td><td>${mb.maxMemorySize}</td></tr>`;
                    if (mb.eccSupported) part2Rows += `<tr><td>Поддержка ECC</td><td>${mb.eccSupported}</td></tr>`;
                    if (mb.pciExpress50x16) part2Rows += `<tr><td>PCI Express 5.0 x16</td><td>${mb.pciExpress50x16}</td></tr>`;
                    if (mb.pciExpressX4) part2Rows += `<tr><td>PCI Express x4</td><td>${mb.pciExpressX4}</td></tr>`;
                    if (mb.pciExpressX1) part2Rows += `<tr><td>PCI Express x1</td><td>${mb.pciExpressX1}</td></tr>`;
                    if (mb.sataPorts) part2Rows += `<tr><td>SATA порты</td><td>${mb.sataPorts}</td></tr>`;
                    if (mb.m2Slots) part2Rows += `<tr><td>M.2 слоты</td><td>${mb.m2Slots}</td></tr>`;
                    if (mb.audioChipset) part2Rows += `<tr><td>Аудио чипсет</td><td>${mb.audioChipset}</td></tr>`;
                    if (mb.audioChannels) part2Rows += `<tr><td>Аудио каналы</td><td>${mb.audioChannels}</td></tr>`;
                    if (mb.lanChipset) part2Rows += `<tr><td>LAN чипсет</td><td>${mb.lanChipset}</td></tr>`;
                    if (mb.maxLanSpeed) part2Rows += `<tr><td>Скорость LAN (Мбит/с)</td><td>${mb.maxLanSpeed}</td></tr>`;
                    if (mb.wirelessLan) part2Rows += `<tr><td>Wi-Fi</td><td>${mb.wirelessLan}</td></tr>`;
                    if (mb.bluetooth) part2Rows += `<tr><td>Bluetooth</td><td>${mb.bluetooth}</td></tr>`;
                    if (mb.rearPanelPorts) part2Rows += `<tr><td>Задние порты IO</td><td>${mb.rearPanelPorts}</td></tr>`;
                    if (mb.internalIoConnectors) part2Rows += `<tr><td>Внутренние разъёмы IO</td><td>${mb.internalIoConnectors}</td></tr>`;
                    if (mb.ledLighting) part2Rows += `<tr><td>Подсветка</td><td>${mb.ledLighting}</td></tr>`;
                    if (mb.dimensions) part2Rows += `<tr><td>Размеры (Д x Ш, дюймы)</td><td>${mb.dimensions}</td></tr>`;
                    if (mb.powerConnectors) part2Rows += `<tr><td>Разъёмы питания</td><td>${mb.powerConnectors}</td></tr>`;
                    if (mb.biosFeature) part2Rows += `<tr><td>Особенности BIOS</td><td>${mb.biosFeature}</td></tr>`;
                    if (mb.features) part2Rows += `<tr><td>Особенности</td><td>${mb.features}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${mb.brand} ${mb.model}`;
                    const imageUrl = mb.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${mb.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${mb.id}" data-name="${title}" data-price="${mb.price}" data-tdp="0" data-image="${imageUrl}" data-type="Материнская плата" data-memory-slots="${mb.memorySlots}"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                                <h5 class="mb-0">${title}</h5>
                            </div>
                            <div class="text-end">
                                ${priceHtml}
                                ${selectBtn}
                            </div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: parseInt(this.dataset.tdp) || 0,
                            imageUrl: this.dataset.image,
                            memorySlots: this.dataset.memorySlots ? parseInt(this.dataset.memorySlots) : null
                        };
                        if (typeof addToBuild === 'function') addToBuild(component);
                        bootstrap.Modal.getInstance(document.getElementById('motherboardModal')).hide();
                    });

                    const modal = new bootstrap.Modal(document.getElementById('motherboardModal'));
                    modal.show();
                } catch (error) {
                    console.error(error);
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== ФИЛЬТРАЦИЯ ПО СОВМЕСТИМОСТИ ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const mbCards = document.querySelectorAll('.motherboard-card');

        function extractMemoryType(memSpeed) {
            if (!memSpeed) return null;
            const match = memSpeed.match(/DDR\d+/i);
            return match ? match[0].toUpperCase() : null;
        }

        async function applyCompatibilityFilter() {
            if (!compatibilitySwitch.checked) {
                mbCards.forEach(card => card.closest('.col').style.display = '');
                return;
            }

            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                const processor = build.find(c => c.type === "Процессор");
                const memoryModules = build.filter(c => c.type === "Оперативная память");
                const pcCase = build.find(c => c.type === "Корпус");

                mbCards.forEach(card => {
                    const col = card.closest('.col');
                    const mbSocket = card.dataset.socket || '';
                    const mbMemoryStandard = (card.dataset.memoryStandard || '').toUpperCase();
                    const mbFormFactor = (card.dataset.formFactor || '').trim();

                    let visible = true;

                    // 1. Проверка сокета процессора
                    if (processor && processor.processorSocket) {
                        if (!mbSocket.includes(processor.processorSocket.replace('Socket ', ''))) {
                            visible = false;
                        }
                    }

                    // 2. Проверка типа памяти
                    if (visible && memoryModules.length > 0) {
                        const memTypes = memoryModules.map(m => extractMemoryType(m.speed)).filter(Boolean);
                        if (memTypes.length > 0) {
                            const supportsMemory = memTypes.some(mt => mbMemoryStandard.includes(mt));
                            if (!supportsMemory) visible = false;
                        }
                    }

                    // 3. Проверка форм‑фактора корпуса
                    if (visible && pcCase && pcCase.caseMotherboardFormFactors) {
                        if (!pcCase.caseMotherboardFormFactors.toLowerCase().includes(mbFormFactor.toLowerCase())) {
                            visible = false;
                        }
                    }

                    col.style.display = visible ? '' : 'none';
                });
            } catch (error) {
                console.error('Ошибка при получении сборки:', error);
                mbCards.forEach(card => card.closest('.col').style.display = '');
            }
        }

        compatibilitySwitch.addEventListener('change', applyCompatibilityFilter);
        applyCompatibilityFilter();
    </script>
}