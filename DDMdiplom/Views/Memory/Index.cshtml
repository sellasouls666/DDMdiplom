@model IEnumerable<DDMdiplom.Models.Memory>

@{
    ViewData["Title"] = "Оперативная память";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* стили карточек памяти (оставлены без изменений) */
        .memory-card {
            border-radius: 20px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;
            height: 100%; cursor: pointer; width: 100%; max-width: 280px; margin: 0 auto;
            display: flex; flex-direction: column;
        }
        .memory-card:hover { transform: translateY(-5px); box-shadow: 0 12px 24px rgba(0,0,0,0.1); }
        .card-img-container { height: 220px; background: #f8f9fa; display: flex; align-items: center; justify-content: center; padding: 8px; }
        .card-img-top { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
        .card-body { padding: 12px 12px 4px 12px; }
        .card-title { font-size: 1rem; font-weight: 600; margin-bottom: 10px; line-height: 1.3; }
        .spec-badge { background: #f1f3f5; padding: 4px 8px; border-radius: 8px; font-size: 0.75rem; color: #495057; display: inline-block; white-space: nowrap; }
        .card-specs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
        .price { font-size: 1.25rem; font-weight: 700; color: #1e2a3e; white-space: nowrap; }
        .btn-outline-add { border-radius: 40px; padding: 5px 14px; font-size: 0.8rem; white-space: nowrap; }
        .card-footer { padding: 0 12px 14px 12px; background: transparent; border: none; }
        .card-footer .d-flex { gap: 8px; flex-wrap: wrap; justify-content: space-between; align-items: center; }
        .memory-grid { display: flex; flex-wrap: wrap; justify-content: flex-start; gap: 24px; }
        .memory-grid .col { flex: 0 0 280px; max-width: 280px; }
        .modal-specs-table { width: 100%; margin-bottom: 20px; }
        .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
        .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
        .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
        .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
    </style>
}

<div class="container">
    <h1 class="mb-3">Оперативная память</h1>
    
    <!-- Переключатель совместимости -->
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <div class="memory-grid">
        @foreach (var mem in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(mem.ImageUrl) ? mem.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card memory-card h-100" data-id="@mem.Id" data-speed="@mem.Speed">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@mem.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@mem.Brand @mem.Model</h5>
                        <div class="card-specs">
                            <span class="spec-badge"><i class="bi bi-speedometer2"></i> @(mem.Speed ?? "—")</span>
                            <span class="spec-badge"><i class="bi bi-memory"></i> @(mem.Capacity ?? "—")</span>
                            <span class="spec-badge"><i class="bi bi-palette"></i> @(mem.Color ?? "—")</span>
                            <span class="spec-badge"><i class="bi bi-layout-text-window"></i> @(mem.CasLatency ?? "—")</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", mem.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@mem.Id"
                                    data-name="@mem.Brand @mem.Model"
                                    data-price="@mem.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Оперативная память"
                                    data-module-count="@mem.ModuleCount">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно деталей -->
<div class="modal fade" id="memoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // Обработчики кнопок "Выбрать"
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: parseInt(this.dataset.tdp) || 0,
                    imageUrl: this.dataset.image,
                    moduleCount: parseInt(this.dataset.moduleCount) || 1
                };
                if (typeof window.addToBuild === 'function') {
                    window.addToBuild(component);
                } else {
                    fetch('/PcBuilder/AddComponent', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(component)
                    }).then(() => location.reload());
                }
            });
        });

        // Модальное окно (без изменений)
        document.querySelectorAll('.memory-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const id = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const resp = await fetch(`/Memory/GetMemory/${id}`);
                    const mem = await resp.json();
                    let part1Rows = '';
                    if (mem.brand) part1Rows += `<tr><td>Бренд</td><td>${mem.brand}</td></tr>`;
                    if (mem.series) part1Rows += `<tr><td>Серия</td><td>${mem.series}</td></tr>`;
                    if (mem.model) part1Rows += `<tr><td>Модель</td><td>${mem.model}</td></tr>`;
                    if (mem.capacity) part1Rows += `<tr><td>Объём (ГБ)</td><td>${mem.capacity}</td></tr>`;
                    if (mem.type) part1Rows += `<tr><td>Тип</td><td>${mem.type}</td></tr>`;
                    if (mem.speed) part1Rows += `<tr><td>Скорость</td><td>${mem.speed}</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    let part2Rows = '';
                    if (mem.casLatency) part2Rows += `<tr><td>CAS Latency</td><td>${mem.casLatency}</td></tr>`;
                    if (mem.timing) part2Rows += `<tr><td>Тайминги</td><td>${mem.timing}</td></tr>`;
                    if (mem.voltage) part2Rows += `<tr><td>Напряжение (В)</td><td>${mem.voltage}</td></tr>`;
                    if (mem.multiChannelKit) part2Rows += `<tr><td>Многоканальный комплект</td><td>${mem.multiChannelKit}</td></tr>`;
                    if (mem.biosProfiles) part2Rows += `<tr><td>Профили BIOS</td><td>${mem.biosProfiles}</td></tr>`;
                    if (mem.color) part2Rows += `<tr><td>Цвет</td><td>${mem.color}</td></tr>`;
                    if (mem.heatSpreader) part2Rows += `<tr><td>Радиатор</td><td>${mem.heatSpreader}</td></tr>`;
                    if (mem.ledColor) part2Rows += `<tr><td>Цвет подсветки</td><td>${mem.ledColor}</td></tr>`;
                    if (mem.recommendUse) part2Rows += `<tr><td>Рекомендуемое использование</td><td>${mem.recommendUse}</td></tr>`;
                    if (mem.features) part2Rows += `<tr><td>Особенности</td><td>${mem.features}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${mem.brand} ${mem.model}`;
                    const imageUrl = mem.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${mem.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${mem.id}" data-name="${title}" data-price="${mem.price}" data-tdp="0" data-image="${imageUrl}" data-type="Оперативная память"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2"><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3"><img src="${imageUrl}" style="width:50px;height:50px;object-fit:contain;"><h5 class="mb-0">${title}</h5></div>
                            <div class="text-end">${priceHtml}${selectBtn}</div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: 0,
                            imageUrl: this.dataset.image,
                            moduleCount: 1
                        };
                        if (typeof window.addToBuild === 'function') window.addToBuild(component);
                        else fetch('/PcBuilder/AddComponent', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(component) }).then(() => location.reload());
                        bootstrap.Modal.getInstance(document.getElementById('memoryModal')).hide();
                    });

                    new bootstrap.Modal(document.getElementById('memoryModal')).show();
                } catch(e) {
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== ФИЛЬТР СОВМЕСТИМОСТИ ПАМЯТИ ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const memoryCards = document.querySelectorAll('.memory-card');

        function extractMemoryType(speedString) {
            if (!speedString) return null;
            const match = speedString.match(/DDR\d+/i);
            return match ? match[0].toUpperCase() : null;
        }

        function extractMemoryTypesFromList(listString) {
            if (!listString) return [];
            const matches = listString.match(/DDR\d+/gi);
            return matches ? [...new Set(matches.map(m => m.toUpperCase()))] : [];
        }

        async function applyMemoryFilter() {
            if (!compatibilitySwitch.checked) {
                memoryCards.forEach(card => card.closest('.col').style.display = '');
                return;
            }

            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                const processor = build.find(c => c.type === "Процессор");
                const motherboard = build.find(c => c.type === "Материнская плата");
                const existingMemory = build.filter(c => c.type === "Оперативная память");

                let allowedTypes = null;

                if (existingMemory.length > 0) {
                    // Ограничиваем типом уже установленной памяти
                    const firstType = extractMemoryType(existingMemory[0].speed);
                    if (firstType) {
                        allowedTypes = [firstType];
                    }
                } else {
                    const procTypes = processor?.processorMemoryTypes;
                    const mbTypes = motherboard?.mbMemoryStandard;

                    const procSet = new Set(extractMemoryTypesFromList(procTypes));
                    const mbSet = new Set(extractMemoryTypesFromList(mbTypes));

                    if (procSet.size > 0 && mbSet.size > 0) {
                        // Пересечение требований процессора и материнской платы
                        allowedTypes = [...procSet].filter(t => mbSet.has(t));
                        if (allowedTypes.length === 0) {
                            // Несовместимы – ничего не показываем
                            allowedTypes = [];
                        }
                    } else if (procSet.size > 0) {
                        allowedTypes = [...procSet];
                    } else if (mbSet.size > 0) {
                        allowedTypes = [...mbSet];
                    }
                }

                memoryCards.forEach(card => {
                    const col = card.closest('.col');
                    const memType = extractMemoryType(card.dataset.speed);
                    if (allowedTypes === null) {
                        col.style.display = '';
                    } else if (allowedTypes.length === 0) {
                        col.style.display = 'none';
                    } else {
                        col.style.display = memType && allowedTypes.includes(memType) ? '' : 'none';
                    }
                });
            } catch (error) {
                console.error('Ошибка фильтра памяти:', error);
                memoryCards.forEach(card => card.closest('.col').style.display = '');
            }
        }

        compatibilitySwitch.addEventListener('change', applyMemoryFilter);
        applyMemoryFilter();
    </script>
}