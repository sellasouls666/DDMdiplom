@model List<DDMdiplom.ViewModels.BuildSummaryViewModel>
@{
    ViewData["Title"] = "Мои конфигурации";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --black: #111;
        --white: #fff;
        --gray-50: #fafafa;
        --gray-100: #f4f4f5;
        --gray-200: #e4e4e7;
        --gray-300: #d4d4d8;
        --gray-500: #71717a;
        --gray-700: #3f3f46;
        --gray-900: #18181b;
        --radius: 16px;
        --radius-sm: 12px;
        --transition: 0.2s ease;
    }

    .builds-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

        .builds-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            margin: 0;
            color: var(--black);
        }

    .btn-create {
        background: var(--black);
        color: var(--white);
        border-radius: 40px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: all var(--transition);
        border: 1px solid var(--black);
    }

        .btn-create:hover {
            background: var(--white);
            color: var(--black);
            transform: translateY(-1px);
        }

    /* Карточка сборки */
    .build-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--gray-200);
        transition: box-shadow var(--transition), transform var(--transition);
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .build-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.1);
            border-color: var(--gray-300);
        }

    .card-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        background: var(--white);
    }

    .build-name {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 0.25rem 0;
        color: var(--black);
    }

    .build-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.85rem;
        color: var(--gray-500);
        flex-wrap: wrap;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-icon-sm {
        background: transparent;
        border: 1px solid var(--gray-200);
        border-radius: 30px;
        padding: 0.2rem 0.8rem;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all var(--transition);
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .btn-icon-sm:hover {
            background: var(--gray-100);
            border-color: var(--gray-300);
        }

    /* Компоненты в сетке */
    .components-grid {
        padding: 1.25rem 1.5rem;
        flex: 1;
    }

    .component-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--gray-100);
    }

        .component-row:last-child {
            border-bottom: none;
        }

    .component-icon {
        width: 36px;
        height: 36px;
        background: var(--gray-100);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: var(--gray-700);
        flex-shrink: 0;
    }

    .component-info {
        flex: 1;
        min-width: 0;
    }

    .component-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--gray-900);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .component-specs {
        font-size: 0.7rem;
        color: var(--gray-500);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-top: 2px;
    }

    .component-price {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--black);
        flex-shrink: 0;
    }

    /* Футер карточки */
    .card-footer {
        background: var(--gray-50);
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .total-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--black);
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .btn-icon {
        background: transparent;
        border: 1px solid var(--gray-200);
        border-radius: 30px;
        padding: 0.4rem 1rem;
        font-size: 0.8rem;
        font-weight: 500;
        transition: all var(--transition);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

        .btn-icon:hover {
            background: var(--gray-100);
            border-color: var(--gray-300);
        }

    .btn-danger-outline {
        color: #b91c1c;
        border-color: #fecaca;
    }

        .btn-danger-outline:hover {
            background: #fee2e2;
            color: #991b1b;
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--gray-200);
    }

    .empty-icon {
        font-size: 4rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
    }

    /* Модальное окно – список всех компонентов */
    .component-detail-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--gray-100);
    }

    .component-detail-icon {
        width: 40px;
        height: 40px;
        background: var(--gray-100);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    .component-detail-info {
        flex: 1;
    }

    .component-detail-name {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .component-detail-specs {
        font-size: 0.75rem;
        color: var(--gray-500);
    }

    .component-detail-price {
        font-weight: 600;
        white-space: nowrap;
    }

    /* адаптив */
    @@media (max-width: 768px) {
        .builds-header {
            flex-direction: column;
            align-items: stretch;
        }

        .card-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .action-buttons {
            justify-content: space-between;
        }

        .component-row {
            flex-wrap: wrap;
        }

        .component-specs {
            white-space: normal;
        }

        .build-meta {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="container py-4">
    <div class="builds-header">
        <h1><i class="bi bi-pc-display me-2"></i>Мои конфигурации</h1>
        <a href="/PcBuilder/ClearAndGoToProcessors" class="btn-create">
            <i class="bi bi-plus-lg me-2"></i>Новая сборка
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-pc-display"></i></div>
            <h5 class="fw-bold">У вас пока нет сохранённых конфигураций</h5>
            <p class="text-muted">Создайте свою первую сборку ПК через конфигуратор</p>
            <a href="/PcBuilder/ClearAndGoToProcessors" class="btn btn-dark rounded-pill px-4 mt-2">Создать сборку</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var build in Model)
            {
                <div class="col-12 col-lg-6">
                    <div class="build-card">
                        <div class="card-header">
                            <h5 class="build-name">@build.Name</h5>
                            <div class="build-meta">
                                <span class="meta-item"><i class="bi bi-grid-3x3-gap-fill"></i> @build.ComponentCount компонентов</span>
                                <span class="meta-item"><i class="bi bi-cash-stack"></i> @build.TotalPrice.ToString("N0") ₽</span>
                                <button class="btn-icon-sm" onclick="event.stopPropagation(); showAllComponents(@build.Id, '@build.Name.Replace("'", "\\'")')">
                                    <i class="bi bi-eye"></i> Все компоненты
                                </button>
                            </div>
                        </div>

                        <div class="components-grid">
                            @foreach (var comp in build.Previews)
                            {
                                <div class="component-row">
                                    <div class="component-icon">
                                        <i class="@GetIconForType(comp.Type)"></i>
                                    </div>
                                    <div class="component-info">
                                        <div class="component-name" title="@comp.Name">@comp.Name</div>
                                        <div class="component-specs">@comp.ShortSpecs</div>
                                    </div>
                                    <div class="component-price">@comp.Price.ToString("N0") ₽</div>
                                </div>
                            }
                        </div>

                        <div class="card-footer">
                            <div class="total-price">@build.TotalPrice.ToString("N0") ₽</div>
                            <div class="action-buttons">
                                <a href="/PcBuilder/EditBuild/@build.Id" class="btn-icon">
                                    <i class="bi bi-pencil"></i> Править
                                </a>
                                <button type="button" onclick="addToCartHandler(event, @build.Id)" class="btn-icon">
                                    <i class="bi bi-cart-plus"></i> В корзину
                                </button>
                                <form asp-action="Delete" asp-route-id="@build.Id" method="post" class="d-inline"
                                      onsubmit="event.stopPropagation(); return confirm('Удалить конфигурацию?');">
                                    <button type="submit" class="btn-icon btn-danger-outline">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Модальное окно для всех компонентов -->
<div class="modal fade" id="allComponentsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="allComponentsModalLabel">Компоненты конфигурации</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="allComponentsContent">
                    <div class="text-center py-4">
                        <div class="spinner-border" role="status"></div>
                        <p class="mt-2">Загрузка...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetIconForType(string type)
    {
        return type switch
        {
            "Процессор" => "bi-cpu",
            "Видеокарта" => "bi-gpu-card",
            "Материнская плата" => "bi-motherboard",
            "Оперативная память" => "bi-memory",
            "Накопитель" => "bi-hdd-stack",
            "Блок питания" => "bi-plug",
            "Корпус" => "bi-pc-display",
            "Система охлаждения" => "bi-fan",
            "Операционная система" => "bi-windows",
            "Монитор" => "bi-display",
            "Источник бесперебойного питания" => "bi-battery-charging",
            "Клавиатура" => "bi-keyboard",
            "Мышь" => "bi-mouse",
            _ => "bi-question-circle"
        };
    }
}

@section Scripts {
    <script>
        const requiredTypes = [
            "Процессор", "Материнская плата", "Видеокарта",
            "Оперативная память", "Накопитель", "Блок питания",
            "Корпус", "Система охлаждения"
        ];

        function addToCartHandler(event, buildId) {
            event.stopPropagation();
            addToCartFromCard(buildId);
        }

        async function addToCartFromCard(buildId) {
            try {
                const buildResponse = await fetch(`/PcBuilder/GetBuildById?buildId=${buildId}`);
                if (!buildResponse.ok) throw new Error('Не удалось загрузить конфигурацию.');
                const buildData = await buildResponse.json();
                const currentBuild = buildData.components;

                const missing = requiredTypes.filter(type => !currentBuild.some(c => c.type === type));
                if (missing.length > 0) {
                    alert(`Конфигурация неполная. Отсутствуют: ${missing.join(', ')}.`);
                    return;
                }

                const issues = getCompatibilityIssues(currentBuild);
                if (issues.length > 0) {
                    alert(`Обнаружены несовместимости:\n${issues.join('\n')}\n\nНевозможно добавить в корзину несовместимую конфигурацию.`);
                    return;
                }

                const response = await fetch('/Cart/Add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ buildId: buildId })
                });

                if (response.ok) {
                    alert('Конфигурация добавлена в корзину!');
                    window.location.href = '/Cart';
                } else {
                    const errorText = await response.text();
                    alert('Ошибка: ' + errorText);
                }
            } catch (err) {
                console.error(err);
                alert('Произошла ошибка при добавлении в корзину');
            }
        }

        function getCompatibilityIssues(currentBuild) {
            const issues = [];
            const cpu = currentBuild.find(c => c.type === "Процессор");
            const mb = currentBuild.find(c => c.type === "Материнская плата");
            const memoryModules = currentBuild.filter(c => c.type === "Оперативная память");
            const gpu = currentBuild.find(c => c.type === "Видеокарта");
            const psu = currentBuild.find(c => c.type === "Блок питания");
            const pcCase = currentBuild.find(c => c.type === "Корпус");
            const cooler = currentBuild.find(c => c.type === "Система охлаждения");
            const storageItems = currentBuild.filter(c => c.type === "Накопитель");

            if (cpu && mb && cpu.processorSocket && mb.cpuSocketType) {
                const cpuSock = cpu.processorSocket.replace('Socket ', '').trim().toUpperCase();
                const mbSock = mb.cpuSocketType.trim().toUpperCase();
                if (!cpuSock.includes(mbSock) && !mbSock.includes(cpuSock)) {
                    issues.push(`Сокет процессора (${cpu.processorSocket}) не совместим с сокетом материнской платы (${mb.cpuSocketType}).`);
                }
            }

            if (cpu && memoryModules.length > 0 && cpu.processorMemoryTypes) {
                const procMemTypes = cpu.processorMemoryTypes.toUpperCase();
                memoryModules.forEach(mem => {
                    if (mem.speed) {
                        const ddrMatch = mem.speed.match(/DDR\d+/i);
                        if (ddrMatch && !procMemTypes.includes(ddrMatch[0].toUpperCase())) {
                            issues.push(`Модуль памяти ${mem.name} (${mem.speed}) не поддерживается процессором.`);
                        }
                    }
                });
            }

            if (mb && memoryModules.length > 0 && mb.mbMemoryStandard) {
                const mbMemStd = mb.mbMemoryStandard.toUpperCase();
                memoryModules.forEach(mem => {
                    if (mem.speed) {
                        const ddrMatch = mem.speed.match(/DDR\d+/i);
                        if (ddrMatch && !mbMemStd.includes(ddrMatch[0].toUpperCase())) {
                            issues.push(`Модуль памяти ${mem.name} (${mem.speed}) не поддерживается материнской платой.`);
                        }
                    }
                });
            }

            if (cooler) {
                if (cooler.cpuSocketCompatibility) {
                    if (cpu && cpu.processorSocket) {
                        const cpuSock = cpu.processorSocket.replace('Socket ', '').trim().toUpperCase();
                        if (!cooler.cpuSocketCompatibility.toUpperCase().includes(cpuSock)) {
                            issues.push(`Воздушный кулер ${cooler.name} не совместим с процессором (сокет ${cpu.processorSocket}).`);
                        }
                    }
                    if (mb && mb.cpuSocketType) {
                        const mbSock = mb.cpuSocketType.trim().toUpperCase();
                        if (!cooler.cpuSocketCompatibility.toUpperCase().includes(mbSock)) {
                            issues.push(`Воздушный кулер ${cooler.name} не совместим с материнской платой (сокет ${mb.cpuSocketType}).`);
                        }
                    }
                } else if (cooler.blockCompatibility) {
                    if (cpu && cpu.processorSocket) {
                        const cpuSock = cpu.processorSocket.replace('Socket ', '').trim().toUpperCase();
                        if (!cooler.blockCompatibility.toUpperCase().includes(cpuSock)) {
                            issues.push(`Жидкостное охлаждение ${cooler.name} не совместимо с процессором (сокет ${cpu.processorSocket}).`);
                        }
                    }
                    if (mb && mb.cpuSocketType) {
                        const mbSock = mb.cpuSocketType.trim().toUpperCase();
                        if (!cooler.blockCompatibility.toUpperCase().includes(mbSock)) {
                            issues.push(`Жидкостное охлаждение ${cooler.name} не совместимо с материнской платой (сокет ${mb.cpuSocketType}).`);
                        }
                    }
                }
            }

            if (gpu && pcCase && gpu.gpuLength && pcCase.maxGpuLength) {
                if (gpu.gpuLength > pcCase.maxGpuLength) {
                    issues.push(`Длина видеокарты (${gpu.gpuLength} мм) превышает максимальную длину, поддерживаемую корпусом (${pcCase.maxGpuLength} мм).`);
                }
            }

            if (psu && pcCase && psu.psuLength && pcCase.maxPsuLength) {
                if (psu.psuLength > pcCase.maxPsuLength) {
                    issues.push(`Длина блока питания (${psu.psuLength} мм) превышает максимальную длину, поддерживаемую корпусом (${pcCase.maxPsuLength} мм).`);
                }
            }

            if (psu && psu.psuMaximumPower) {
                const totalTdp = currentBuild.reduce((sum, c) => sum + (c.tdp || 0), 0);
                const required = totalTdp + 200;
                if (psu.psuMaximumPower < required) {
                    issues.push(`Мощность блока питания (${psu.psuMaximumPower} Вт) недостаточна. Требуется минимум ${required} Вт (с учётом запаса 200 Вт).`);
                }
            }

            if (mb && storageItems.some(s => s.storageInterface === "M.2")) {
                if (!mb.m2Slots || mb.m2Slots <= 0) {
                    issues.push(`В материнской плате нет слотов M.2, но выбран M.2 SSD.`);
                } else {
                    const m2Count = storageItems.filter(s => s.storageInterface === "M.2").length;
                    if (m2Count > mb.m2Slots) {
                        issues.push(`Количество M.2 накопителей (${m2Count}) превышает количество слотов M.2 на материнской плате (${mb.m2Slots}).`);
                    }
                }
            }

            if (mb && pcCase && mb.mbFormFactor && pcCase.caseMotherboardFormFactors) {
                const mbForm = mb.mbFormFactor.trim().toLowerCase();
                const caseForms = pcCase.caseMotherboardFormFactors.toLowerCase();
                if (!caseForms.includes(mbForm)) {
                    issues.push(`Форм-фактор материнской платы (${mb.mbFormFactor}) не поддерживается корпусом (${pcCase.caseMotherboardFormFactors}).`);
                }
            }

            if (mb && memoryModules.length > 0) {
                const totalModules = memoryModules.reduce((sum, m) => sum + (m.moduleCount || 1), 0);
                if (mb.memorySlots && totalModules > mb.memorySlots) {
                    issues.push(`Количество установленных модулей памяти (${totalModules}) превышает количество слотов на материнской плате (${mb.memorySlots}).`);
                }
            }

            return issues;
        }

        // Функция показа всех компонентов сборки
        async function showAllComponents(buildId, buildName) {
            const modalEl = document.getElementById('allComponentsModal');
            const modal = new bootstrap.Modal(modalEl);
            const modalTitle = document.getElementById('allComponentsModalLabel');
            const modalBody = document.getElementById('allComponentsContent');
            
            modalTitle.innerText = `Компоненты: ${buildName}`;
            modalBody.innerHTML = '<div class="text-center py-4"><div class="spinner-border" role="status"></div><p class="mt-2">Загрузка...</p></div>';
            modal.show();

            try {
                const response = await fetch(`/MyBuilds/GetBuildDetails/${buildId}`);
                if (!response.ok) throw new Error('Ошибка загрузки');
                const components = await response.json();
                
                if (components.length === 0) {
                    modalBody.innerHTML = '<div class="alert alert-info">Компоненты не найдены.</div>';
                    return;
                }

                let html = '<div class="list-group list-group-flush">';
                components.forEach(comp => {
                    const icon = getIconForTypeClient(comp.type);
                    html += `
                        <div class="component-detail-row">
                            <div class="component-detail-icon">
                                <i class="bi ${icon}"></i>
                            </div>
                            <div class="component-detail-info">
                                <div class="component-detail-name">${escapeHtml(comp.name)}</div>
                                <div class="component-detail-specs">${escapeHtml(comp.shortSpecs || '—')}</div>
                            </div>
                            <div class="component-detail-price">${Number(comp.price).toLocaleString()} ₽</div>
                        </div>
                    `;
                });
                html += '</div>';
                modalBody.innerHTML = html;
            } catch (error) {
                modalBody.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                console.error(error);
            }
        }

        function getIconForTypeClient(type) {
            const icons = {
                "Процессор": "bi-cpu",
                "Видеокарта": "bi-gpu-card",
                "Материнская плата": "bi-motherboard",
                "Оперативная память": "bi-memory",
                "Накопитель": "bi-hdd-stack",
                "Блок питания": "bi-plug",
                "Корпус": "bi-pc-display",
                "Система охлаждения": "bi-fan",
                "Операционная система": "bi-windows",
                "Монитор": "bi-display",
                "Источник бесперебойного питания": "bi-battery-charging",
                "Клавиатура": "bi-keyboard",
                "Мышь": "bi-mouse"
            };
            return icons[type] || "bi-question-circle";
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
    </script>
}