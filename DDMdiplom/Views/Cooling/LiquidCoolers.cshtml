@model IEnumerable<DDMdiplom.Models.WaterCooler>

@{
    ViewData["Title"] = "Жидкостное охлаждение";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ========== Карточки СЖО ========== */
        .water-card {
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
        }
        .water-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        }
        .card-img-container {
            height: 220px;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }
        .card-img-top {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
        }
        .water-card:hover .card-img-top {
            transform: scale(1.02);
        }
        .card-body {
            padding: 12px 12px 4px 12px;
        }
        .card-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.3;
        }
        .spec-badge {
            background: #f1f3f5;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 0.75rem;
            color: #495057;
            display: inline-block;
            white-space: nowrap;
        }
        .card-specs {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 10px;
        }
        .price {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e2a3e;
            white-space: nowrap;
        }
        .btn-outline-add {
            border-radius: 40px;
            padding: 5px 14px;
            font-size: 0.8rem;
            white-space: nowrap;
        }
        .card-footer {
            padding: 0 12px 14px 12px;
            background: transparent;
            border: none;
        }
        .card-footer .d-flex {
            gap: 8px;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }
        .water-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 24px;
        }
        .water-grid .col {
            flex: 0 0 280px;
            max-width: 280px;
        }

        /* Модальное окно */
        .modal-specs-table { width: 100%; margin-bottom: 20px; }
        .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
        .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
        .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
        .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
    </style>
}

<div class="container">
    <h1 class="mb-3">Жидкостное охлаждение</h1>

    <!-- Переключатель совместимости -->
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <div class="water-grid">
        @foreach (var item in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(item.ImageUrl) ? item.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card water-card h-100"
                     data-id="@item.Id"
                     data-block-compat="@item.BlockCompatibility">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@item.Brand @item.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@item.Brand @item.Model</h5>
                        <div class="card-specs">
                            @if (!string.IsNullOrEmpty(item.FanSize))
                            {
                                <span class="spec-badge"><i class="bi bi-fan"></i> @item.FanSize</span>
                            }
                            @if (!string.IsNullOrEmpty(item.Color))
                            {
                                <span class="spec-badge"><i class="bi bi-palette"></i> @item.Color</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", item.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@item.Id"
                                    data-name="@item.Brand @item.Model"
                                    data-price="@item.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Система охлаждения">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно для деталей СЖО -->
<div class="modal fade" id="waterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // Обработчики для кнопок "Выбрать"
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: 0,
                    imageUrl: this.dataset.image
                };
                if (typeof addToBuild === 'function') {
                    addToBuild(component);
                } else {
                    console.error('addToBuild not defined');
                }
            });
        });

        // Открытие модального окна по клику на карточку
        document.querySelectorAll('.water-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const itemId = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const response = await fetch(`/Cooling/GetWaterCooler/${itemId}`);
                    const item = await response.json();

                    // Основная информация
                    let part1Rows = '';
                    if (item.brand) part1Rows += `<tr><td>Бренд</td><td>${item.brand}</td></tr>`;
                    if (item.type) part1Rows += `<tr><td>Тип</td><td>${item.type}</td></tr>`;
                    if (item.blockCompatibility) part1Rows += `<tr><td>Совместимость с сокетами</td><td>${item.blockCompatibility}</td></tr>`;
                    if (item.radiatorSize) part1Rows += `<tr><td>Размер радиатора</td><td>${item.radiatorSize}</td></tr>`;
                    if (item.fanCount) part1Rows += `<tr><td>Количество вентиляторов</td><td>${item.fanCount}</td></tr>`;
                    if (item.fanSize) part1Rows += `<tr><td>Размер вентиляторов</td><td>${item.fanSize}</td></tr>`;
                    if (item.color) part1Rows += `<tr><td>Цвет</td><td>${item.color}</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    // Детальные характеристики
                    let part2Rows = '';
                    if (item.pumpSpeed) part2Rows += `<tr><td>Скорость помпы</td><td>${item.pumpSpeed}</td></tr>`;
                    if (item.pumpNoise) part2Rows += `<tr><td>Шум помпы</td><td>${item.pumpNoise}</td></tr>`;
                    if (item.radiatorMaterial) part2Rows += `<tr><td>Материал радиатора</td><td>${item.radiatorMaterial}</td></tr>`;
                    if (item.fanRpm) part2Rows += `<tr><td>Скорость вентиляторов</td><td>${item.fanRpm}</td></tr>`;
                    if (item.fanAirFlow) part2Rows += `<tr><td>Воздушный поток</td><td>${item.fanAirFlow}</td></tr>`;
                    if (item.fanNoise) part2Rows += `<tr><td>Уровень шума</td><td>${item.fanNoise}</td></tr>`;
                    if (item.pressure) part2Rows += `<tr><td>Статическое давление</td><td>${item.pressure}</td></tr>`;
                    if (item.tubeDimensions) part2Rows += `<tr><td>Длина трубок</td><td>${item.tubeDimensions}</td></tr>`;
                    if (item.tubeMaterial) part2Rows += `<tr><td>Материал трубок</td><td>${item.tubeMaterial}</td></tr>`;
                    if (item.ledColor) part2Rows += `<tr><td>Цвет подсветки</td><td>${item.ledColor}</td></tr>`;
                    if (item.features) part2Rows += `<tr><td>Особенности</td><td>${item.features}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${item.brand} ${item.model || ''}`;
                    const imageUrl = item.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${item.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${item.id}" data-name="${title}" data-price="${item.price}" data-tdp="0" data-image="${imageUrl}" data-type="Система охлаждения"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                                <h5 class="mb-0">${title}</h5>
                            </div>
                            <div class="text-end">
                                ${priceHtml}
                                ${selectBtn}
                            </div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: 0,
                            imageUrl: this.dataset.image
                        };
                        if (typeof addToBuild === 'function') addToBuild(component);
                    });

                    const modal = new bootstrap.Modal(document.getElementById('waterModal'));
                    modal.show();
                } catch (error) {
                    console.error(error);
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== ФИЛЬТР СОВМЕСТИМОСТИ ВОДЯНКИ (по сокету) ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const waterCards = document.querySelectorAll('.water-card');

        async function applyWaterFilter() {
            if (!compatibilitySwitch.checked) {
                waterCards.forEach(card => card.closest('.col').style.display = '');
                return;
            }

            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                const processor = build.find(c => c.type === "Процессор");
                const motherboard = build.find(c => c.type === "Материнская плата");

                // Собираем требуемые сокеты
                const requiredSockets = [];
                if (processor && processor.processorSocket) {
                    requiredSockets.push(processor.processorSocket.replace('Socket ', '').trim());
                }
                if (motherboard && motherboard.cpuSocketType) {
                    requiredSockets.push(motherboard.cpuSocketType.trim());
                }

                waterCards.forEach(card => {
                    const col = card.closest('.col');
                    const compatStr = card.dataset.blockCompat?.toUpperCase() || '';

                    let visible = true;
                    if (requiredSockets.length > 0) {
                        // Все требуемые сокеты должны присутствовать в строке совместимости кулера
                        visible = requiredSockets.every(socket =>
                            compatStr.includes(socket.toUpperCase())
                        );
                    }
                    col.style.display = visible ? '' : 'none';
                });
            } catch (err) {
                console.error('Ошибка фильтра водянки:', err);
                waterCards.forEach(card => card.closest('.col').style.display = '');
            }
        }

        compatibilitySwitch.addEventListener('change', applyWaterFilter);
        applyWaterFilter();
    </script>
}