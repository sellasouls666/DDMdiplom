@model IEnumerable<DDMdiplom.Models.CpuCooler>

@{
    ViewData["Title"] = "Воздушное охлаждение";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ========== Карточки кулеров ========== */
        .cooler-card {
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
        }
        .cooler-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        }
        .card-img-container {
            height: 220px;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }
        .card-img-top {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
        }
        .cooler-card:hover .card-img-top {
            transform: scale(1.02);
        }
        .card-body {
            padding: 12px 12px 4px 12px;
        }
        .card-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.3;
        }
        .spec-badge {
            background: #f1f3f5;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 0.75rem;
            color: #495057;
            display: inline-block;
            white-space: nowrap;
        }
        .card-specs {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 10px;
        }
        .price {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e2a3e;
            white-space: nowrap;
        }
        .btn-outline-add {
            border-radius: 40px;
            padding: 5px 14px;
            font-size: 0.8rem;
            white-space: nowrap;
        }
        .card-footer {
            padding: 0 12px 14px 12px;
            background: transparent;
            border: none;
        }
        .card-footer .d-flex {
            gap: 8px;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }
        .cooler-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 24px;
        }
        .cooler-grid .col {
            flex: 0 0 280px;
            max-width: 280px;
        }

        /* Модальное окно */
        .modal-specs-table { width: 100%; margin-bottom: 20px; }
        .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
        .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
        .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
        .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
    </style>
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Воздушное охлаждение</h1>
    </div>

    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <div class="cooler-grid">
        @foreach (var cooler in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(cooler.ImageUrl) ? cooler.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card cooler-card h-100"
                     data-id="@cooler.Id"
                     data-socket-compat="@cooler.CpuSocketCompatibility">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@cooler.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@cooler.Brand @cooler.Model</h5>
                        <div class="card-specs">
                            @if (!string.IsNullOrEmpty(cooler.Rpm))
                            {
                                <span class="spec-badge"><i class="bi bi-speedometer2"></i> @cooler.Rpm</span>
                            }
                            @if (!string.IsNullOrEmpty(cooler.NoiseLevel))
                            {
                                <span class="spec-badge"><i class="bi bi-volume-up"></i> @cooler.NoiseLevel</span>
                            }
                            @if (!string.IsNullOrEmpty(cooler.Color))
                            {
                                <span class="spec-badge"><i class="bi bi-palette"></i> @cooler.Color</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", cooler.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@cooler.Id"
                                    data-name="@cooler.Brand @cooler.Model"
                                    data-price="@cooler.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Система охлаждения">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно для деталей кулера -->
<div class="modal fade" id="coolerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // Обработчики для кнопок "Выбрать"
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: 0,
                    imageUrl: this.dataset.image
                };
                if (typeof addToBuild === 'function') {
                    addToBuild(component);
                } else {
                    console.error('addToBuild not defined');
                }
            });
        });

        // Открытие модального окна по клику на карточку
        document.querySelectorAll('.cooler-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const coolerId = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const response = await fetch(`/Cooling/GetCpuCooler/${coolerId}`);
                    const cooler = await response.json();

                    // Основная информация
                    let part1Rows = '';
                    if (cooler.brand) part1Rows += `<tr><td>Бренд</td><td>${cooler.brand}</td></tr>`;
                    if (cooler.series) part1Rows += `<tr><td>Серия</td><td>${cooler.series}</td></tr>`;
                    if (cooler.model) part1Rows += `<tr><td>Модель</td><td>${cooler.model}</td></tr>`;
                    if (cooler.type) part1Rows += `<tr><td>Тип</td><td>${cooler.type}</td></tr>`;
                    if (cooler.fanSize) part1Rows += `<tr><td>Размер вентилятора</td><td>${cooler.fanSize}</td></tr>`;
                    if (cooler.cpuSocketCompatibility) part1Rows += `<tr><td>Совместимость с сокетами</td><td>${cooler.cpuSocketCompatibility}</td></tr>`;
                    if (cooler.maxCpuCoolerHeight) part1Rows += `<tr><td>Макс. высота кулера</td><td>${cooler.maxCpuCoolerHeight} мм</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    // Детальные характеристики
                    let part2Rows = '';
                    if (cooler.bearingType) part2Rows += `<tr><td>Тип подшипника</td><td>${cooler.bearingType}</td></tr>`;
                    if (cooler.rpm) part2Rows += `<tr><td>Скорость вращения</td><td>${cooler.rpm}</td></tr>`;
                    if (cooler.airFlow) part2Rows += `<tr><td>Воздушный поток</td><td>${cooler.airFlow}</td></tr>`;
                    if (cooler.noiseLevel) part2Rows += `<tr><td>Уровень шума</td><td>${cooler.noiseLevel}</td></tr>`;
                    if (cooler.heatsinkMaterial) part2Rows += `<tr><td>Материал радиатора</td><td>${cooler.heatsinkMaterial}</td></tr>`;
                    if (cooler.fanDimensions) part2Rows += `<tr><td>Габариты вентилятора</td><td>${cooler.fanDimensions}</td></tr>`;
                    if (cooler.heatsinkDimensions) part2Rows += `<tr><td>Габариты радиатора</td><td>${cooler.heatsinkDimensions}</td></tr>`;
                    if (cooler.features) part2Rows += `<tr><td>Особенности</td><td>${cooler.features}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${cooler.brand} ${cooler.model}`;
                    const imageUrl = cooler.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${cooler.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${cooler.id}" data-name="${title}" data-price="${cooler.price}" data-tdp="0" data-image="${imageUrl}" data-type="Система охлаждения"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                                <h5 class="mb-0">${title}</h5>
                            </div>
                            <div class="text-end">
                                ${priceHtml}
                                ${selectBtn}
                            </div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: 0,
                            imageUrl: this.dataset.image
                        };
                        if (typeof addToBuild === 'function') addToBuild(component);
                    });

                    const modal = new bootstrap.Modal(document.getElementById('coolerModal'));
                    modal.show();
                } catch (error) {
                    console.error(error);
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== ФИЛЬТР СОВМЕСТИМОСТИ КУЛЕРА ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const coolerCards = document.querySelectorAll('.cooler-card');

        async function applyCoolerFilter() {
            if (!compatibilitySwitch.checked) {
                coolerCards.forEach(card => card.closest('.col').style.display = '');
                return;
            }

            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                const processor = build.find(c => c.type === "Процессор");
                const motherboard = build.find(c => c.type === "Материнская плата");

                // Собираем сокеты, которые должны поддерживаться
                const requiredSockets = [];
                if (processor && processor.processorSocket) {
                    // Убираем возможный префикс "Socket "
                    requiredSockets.push(processor.processorSocket.replace('Socket ', '').trim());
                }
                if (motherboard && motherboard.cpuSocketType) {
                    requiredSockets.push(motherboard.cpuSocketType.trim());
                }

                coolerCards.forEach(card => {
                    const col = card.closest('.col');
                    const compatStr = card.dataset.socketCompat?.toUpperCase() || '';

                    let visible = true;
                    if (requiredSockets.length > 0) {
                        visible = requiredSockets.every(socket =>
                            compatStr.includes(socket.toUpperCase())
                        );
                    }
                    col.style.display = visible ? '' : 'none';
                });
            } catch (err) {
                console.error('Ошибка фильтра кулера:', err);
                coolerCards.forEach(card => card.closest('.col').style.display = '');
            }
        }

        compatibilitySwitch.addEventListener('change', applyCoolerFilter);
        applyCoolerFilter();
    </script>
}