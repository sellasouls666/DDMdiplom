@model IEnumerable<DDMdiplom.Models.Order>
@{
    ViewData["Title"] = "Мои заказы";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #1a1a1a;
        --primary-light: #333;
        --bg: #fafafa;
        --card-bg: #fff;
        --text: #222;
        --text-muted: #666;
        --border: #e5e5e5;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
        --shadow-md: 0 6px 18px rgba(0,0,0,0.06);
        --shadow-lg: 0 12px 32px rgba(0,0,0,0.08);
        --radius: 16px;
        --radius-sm: 10px;
        --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
        background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: var(--text);
        -webkit-font-smoothing: antialiased;
    }

    .orders-wrapper {
        max-width: 900px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 2rem;
        color: var(--primary);
        position: relative;
        display: inline-block;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: -6px;
        left: 0;
        width: 40px;
        height: 3px;
        background: var(--primary);
        border-radius: 2px;
    }

    .order-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 1.75rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        margin-bottom: 1.5rem;
        transition: all var(--transition);
    }

    .order-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .order-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .order-id {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--primary);
        letter-spacing: -0.3px;
    }

    .order-date {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }

    .order-status {
        display: inline-block;
        padding: 0.3rem 1rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-new { background: #e8f5e9; color: #2e7d32; }
    .status-processing { background: #e3f2fd; color: #1565c0; }
    .status-sent { background: #fff3e0; color: #e65100; }
    .status-done { background: #f3e5f5; color: #7b1fa2; }
    .status-canceled { background: #ffebee; color: #c62828; }

    .order-summary {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
    }

    .total-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--primary);
    }

    .items-count {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    .btn-toggle {
        background: transparent;
        border: 2px solid var(--border);
        color: var(--text-muted);
        padding: 0.4rem 1.2rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all var(--transition);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 0.5rem;
    }

    .btn-toggle:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: #f5f5f5;
    }

    .btn-toggle i {
        font-size: 0.9rem;
    }

    .collapse-content {
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 1px dashed var(--border);
    }

    .build-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.95rem;
    }

    .build-item:last-child {
        border-bottom: none;
    }

    .build-name {
        font-weight: 600;
        color: var(--primary);
    }

    .build-price {
        font-weight: 700;
        color: var(--primary);
        white-space: nowrap;
    }

    .show-components-btn {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.2rem 1rem;
        border-radius: 50px;
        transition: all var(--transition);
    }

    .show-components-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: #f5f5f5;
    }

    .components-container {
        margin-top: 0.5rem;
        padding: 0.75rem;
        background: #f9fafb;
        border-radius: var(--radius-sm);
    }

    .empty-orders {
        text-align: center;
        padding: 4rem 1rem;
        color: var(--text-muted);
    }

    .empty-orders i {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.3;
    }

    @@media (max-width: 576px) {
        .order-header {
            flex-direction: column;
        }
        .page-title {
            font-size: 1.6rem;
        }
    }
</style>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="orders-wrapper">
    <h1 class="page-title">Мои заказы</h1>

    @if (!Model.Any())
    {
        <div class="empty-orders">
            <i class="bi bi-inbox"></i>
            <h5>У вас пока нет заказов</h5>
            <p class="text-muted">Как только вы оформите заказ, он появится здесь.</p>
            <a href="/PcBuilder" class="btn btn-dark rounded-pill px-4 mt-2">Создать сборку</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            var statusClass = order.Status switch
            {
                "Новый" => "status-new",
                "В обработке" => "status-processing",
                "Отправлен" => "status-sent",
                "Доставлен" => "status-done",
                "Отменён" => "status-canceled",
                _ => "status-new"
            };

            <div class="order-card">
                <div class="order-header">
                    <div>
                        <div class="order-id">Заказ № @order.Id</div>
                        <div class="order-date">@order.OrderDate.ToLocalTime().ToString("dd MMMM yyyy, HH:mm")</div>
                    </div>
                    <div>
                        <span class="order-status @statusClass">@order.Status</span>
                    </div>
                </div>

                <div class="order-summary">
                    <div>
                        <div class="total-price">@order.TotalPrice.ToString("N0") ₽</div>
                        <div class="items-count">@order.OrderItems.Sum(i => i.Quantity) позиций</div>
                    </div>
                    <div class="d-flex gap-2">
                        @if (order.Status == "Новый" || order.Status == "В обработке")
                        {
                            <form asp-action="CancelOrder" method="post" onsubmit="return confirm('Вы уверены, что хотите отменить заказ №@order.Id?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn-toggle" style="border-color: #dc3545; color: #dc3545;">
                                    <i class="bi bi-x-circle"></i> Отменить
                                </button>
                            </form>
                        }
                        <button class="btn-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#orderItems-@order.Id" aria-expanded="false">
                            <i class="bi bi-chevron-down"></i> Состав
                        </button>
                    </div>
                </div>

                <div class="collapse collapse-content" id="orderItems-@order.Id">
                    @foreach (var item in order.OrderItems)
                    {
                        <div class="build-item">
                            <div>
                                <span class="build-name">@(item.Build?.Name ?? "Сборка")</span>
                                <small class="text-muted ms-2">x@(item.Quantity)</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="build-price">@((item.Price * item.Quantity).ToString("N0")) ₽</div>
                                <button class="show-components-btn ms-3" 
                                        data-build-id="@item.BuildId" 
                                        onclick="toggleComponents(this, @order.Id, @item.BuildId)">
                                    <i class="bi bi-zoom-in"></i> Состав
                                </button>
                            </div>
                        </div>
                        <div class="components-container" id="components-@order.Id-@item.BuildId" style="display:none;"></div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        async function toggleComponents(btn, orderId, buildId) {
            const container = document.getElementById(`components-${orderId}-${buildId}`);
            if (!container) return;

            // Если уже загружено – просто переключаем видимость
            if (container.dataset.loaded === 'true') {
                container.style.display = container.style.display === 'none' ? 'block' : 'none';
                return;
            }

            // Показываем контейнер и ставим спиннер
            container.style.display = 'block';
            container.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-secondary" role="status"></div></div>';

            try {
                const response = await fetch(`/Orders/GetBuildComponents?buildId=${buildId}`);
                if (!response.ok) throw new Error('Ошибка загрузки');
                const html = await response.text();
                container.innerHTML = html;
                container.dataset.loaded = 'true';
            } catch (err) {
                container.innerHTML = '<div class="alert alert-danger py-2">Не удалось загрузить компоненты</div>';
            }
        }
    </script>
}