@using DDMdiplom.ViewModels
@model CheckoutViewModel
@{
    ViewData["Title"] = "Оформление заказа";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #1a1a1a;
        --primary-light: #333;
        --bg: #fafafa;
        --card-bg: #fff;
        --text: #222;
        --text-muted: #666;
        --border: #e5e5e5;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
        --shadow-md: 0 6px 18px rgba(0,0,0,0.06);
        --shadow-lg: 0 12px 32px rgba(0,0,0,0.08);
        --radius: 16px;
        --radius-sm: 10px;
        --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
        background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: var(--text);
        -webkit-font-smoothing: antialiased;
    }

    .checkout-wrapper {
        max-width: 1100px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .checkout-title {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 2rem;
        color: var(--primary);
        position: relative;
        display: inline-block;
    }

        .checkout-title::after {
            content: '';
            position: absolute;
            bottom: -6px;
            left: 0;
            width: 40px;
            height: 3px;
            background: var(--primary);
            border-radius: 2px;
        }

    /* Карточки секций */
    .section-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 2rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        transition: box-shadow var(--transition);
    }

        .section-card:hover {
            box-shadow: var(--shadow-md);
        }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .section-title i {
            font-size: 1.2rem;
            opacity: 0.7;
        }

    /* Поля ввода */
    .form-control, .form-select {
        border: 2px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        transition: all var(--transition);
        background: #fafbfc;
    }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(26,26,26,0.08);
            background: #fff;
            outline: none;
        }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
    }

    /* Кнопка оформления */
    .btn-checkout {
        background: var(--primary);
        color: #fff;
        border: none;
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.3px;
        transition: all var(--transition);
        box-shadow: var(--shadow-sm);
        text-transform: uppercase;
    }

        .btn-checkout:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-checkout:active {
            transform: translateY(0);
        }

    /* Список товаров */
    .order-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .order-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--border);
        transition: background var(--transition);
    }

        .order-item:last-child {
            border-bottom: none;
        }

        .order-item:hover {
            background: #f9fafb;
            margin: 0 -1rem;
            padding-left: 1rem;
            padding-right: 1rem;
            border-radius: var(--radius-sm);
        }

    .item-details h6 {
        margin: 0 0 0.25rem;
        font-weight: 600;
        color: var(--primary);
    }

    .item-details small {
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .item-price {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--primary);
        white-space: nowrap;
    }

    .btn-details {
        background: transparent;
        border: 2px solid var(--border);
        color: var(--text-muted);
        padding: 0.3rem 1rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all var(--transition);
        margin-top: 0.5rem;
    }

        .btn-details:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: #f5f5f5;
        }

    /* Итого */
    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 0 0;
        margin-top: 1rem;
        border-top: 2px solid var(--primary);
        font-size: 1.2rem;
        font-weight: 700;
    }

    .badge-count {
        background: var(--primary);
        color: #fff;
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    /* Модальное окно */
    .modal-content {
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
    }

    .modal-header {
        background: var(--primary);
        color: #fff;
        border-bottom: none;
        padding: 1.25rem 1.5rem;
    }

    .modal-title {
        font-weight: 600;
        font-size: 1.15rem;
    }

    .modal-body {
        padding: 2rem;
    }

    .component-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 1.5rem;
        text-align: center;
    }

    .component-item img {
        width: 80px;
        height: 80px;
        object-fit: contain;
        margin-bottom: 0.5rem;
        transition: transform var(--transition);
    }

    .component-item:hover img {
        transform: scale(1.08);
    }

    .component-item .name {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text);
        word-break: break-word;
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .checkout-title {
            font-size: 1.6rem;
        }

        .section-card {
            padding: 1.25rem;
        }
    }
</style>

<div class="checkout-wrapper">
    <h1 class="checkout-title">Оформление заказа</h1>

    <form asp-action="Checkout" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

        <div class="row g-4">
            <!-- Левая колонка: Данные -->
            <div class="col-lg-7">
                <div class="section-card">
                    <div class="section-title">
                        <i class="bi bi-person-lines-fill"></i> Контактные данные и доставка
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="CustomerName" class="form-label">Полное имя</label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Иванов Иван Иванович" />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Телефон</label>
                            <input asp-for="Phone" class="form-control" placeholder="+7 999 123-45-67" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label">Адрес доставки</label>
                            <input asp-for="Address" class="form-control" placeholder="Город, улица, дом, квартира" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Comment" class="form-label">Комментарий к заказу</label>
                            <textarea asp-for="Comment" class="form-control" rows="3" placeholder="Дополнительная информация..."></textarea>
                            <span asp-validation-for="Comment" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn-checkout w-100">
                            <i class="bi bi-check2-circle me-2"></i> Подтвердить и оплатить
                        </button>
                    </div>
                </div>
            </div>

            <!-- Правая колонка: Состав заказа -->
            <div class="col-lg-5">
                <div class="section-card">
                    <div class="section-title">
                        <i class="bi bi-cart-check"></i> Ваш заказ
                        <span class="badge-count ms-auto">@Model.CartItems.Sum(i => i.Quantity) шт.</span>
                    </div>

                    <ul class="order-list">
                        @foreach (var item in Model.CartItems)
                        {
                            <li class="order-item">
                                <div class="item-details">
                                    <h6>@item.BuildName</h6>
                                    <small>Количество: @item.Quantity</small>
                                    <br />
                                    <button type="button" class="btn-details mt-1" onclick="showComponents(@item.BuildId)">
                                        <i class="bi bi-zoom-in me-1"></i> Состав конфигурации
                                    </button>
                                </div>
                                <div class="item-price">
                                    @((item.Price * item.Quantity).ToString("N0")) ₽
                                </div>
                            </li>
                        }
                    </ul>

                    <div class="total-row">
                        <span>Итого к оплате</span>
                        <span>@Model.TotalPrice.ToString("N0") ₽</span>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Модальное окно комплектующих -->
<div class="modal fade" id="componentsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cpu me-2"></i> Комплектующие конфигурации</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <div class="text-center py-4">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showComponents(buildId) {
            const modalBody = document.getElementById('modalBody');
            modalBody.innerHTML = '<div class="text-center py-4"><div class="spinner-border" role="status"><span class="visually-hidden">Загрузка...</span></div></div>';
            const modal = new bootstrap.Modal(document.getElementById('componentsModal'));
            modal.show();

            fetch('/Orders/GetBuildComponents?buildId=' + buildId)
                .then(response => response.text())
                .then(html => {
                    modalBody.innerHTML = html;
                })
                .catch(() => {
                    modalBody.innerHTML = '<div class="alert alert-danger">Не удалось загрузить компоненты</div>';
                });
        }
    </script>
}