@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{ //получаем имя авторизованного пользователя
    var displayName = "Пользователь";
    if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        displayName = user?.Name ?? User.Identity?.Name ?? "Пользователь";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DDM</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DDMdiplom.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
            .custom-user-btn {
                background-color: transparent !important;
                color: #212529 !important;
                text-decoration: none !important;
            }

                .custom-user-btn:hover {
                    background-color: #e0e0e0 !important;
                    color: #212529 !important;
                }

                .custom-user-btn.disabled {
                    opacity: 0.6;
                    pointer-events: none;
                    cursor: default;
                }

            .navbar .custom-user-btn.custom-user-btn:hover {
                background-color: #e0e0e0 !important;
                background-image: none !important;
            }

            .navbar .custom-user-btn.custom-user-btn {
                background-color: transparent !important;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/favicon.png" alt="Logo" style="height: 30px; width: auto;" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <div class="d-flex ms-auto">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var userName = User.Identity?.Name ?? "Пользователь";
                            <a href="javascript:void(0);" class="nav-link custom-user-btn d-flex align-items-center gap-2" style="border-radius: 40px; padding: 6px 16px; transition: background-color 0.2s;">
                                <i class="bi bi-person" style="font-size: 2rem;"></i>
                                <div class="text-start">
                                    <div style="font-size: 0.7rem; line-height: 1.2;">Добро пожаловать, @displayName</div>
                                    <div style="font-size: 0.9rem; font-weight: 500; line-height: 1.2;">
                                        Личный кабинет
                                        <i class="bi bi-chevron-down" style="font-size: 0.8rem; margin-left: 4px;"></i>
                                    </div>
                                </div>
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Identity" asp-action="SignIn" class="nav-link custom-user-btn d-flex align-items-center gap-2" style="border-radius: 40px; padding: 6px 16px; transition: background-color 0.2s;">
                                <i class="bi bi-person" style="font-size: 2rem;"></i>
                                <div class="text-start">
                                    <div style="font-size: 0.7rem; line-height: 1.2;">Добро пожаловать</div>
                                    <div style="font-size: 0.9rem; font-weight: 500; line-height: 1.2;">Войти / Зарегистрироваться</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - DDMdiplom - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>