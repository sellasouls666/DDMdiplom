@inject Microsoft.AspNetCore.Identity.SignInManager<DDMdiplom.Models.ApplicationUser> SignInManager

<style>
    /* ========== Боковая панель сборки (общие стили) ========== */
    .build-sidebar {
        position: fixed;
        top: 80px;
        right: 0;
        height: calc(100% - 80px);
        background: white;
        box-shadow: -2px 0 12px rgba(0,0,0,0.1);
        transition: width 0.3s ease;
        z-index: 1050;
        font-family: 'Segoe UI', Roboto, sans-serif;
        overflow: visible;
    }
    .build-sidebar.collapsed { width: 240px; }
    .build-sidebar.expanded { width: 400px; }

    .sidebar-toggle {
        position: absolute;
        left: -18px;
        top: 50%;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        background: white;
        border-radius: 50%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 1061;
        border: 1px solid #dee2e6;
        font-size: 1.2rem;
        color: #000;
    }

    .expanded-content {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 20px 16px;
    }
    .collapsed-content {
        display: flex;
        flex-direction: column;
        padding: 16px 12px;
        height: 100%;
    }
    .expanded-content,
    .collapsed-content {
        height: 100%;
        overflow-y: auto;
    }
    .build-sidebar.collapsed .expanded-content { display: none; }
    .build-sidebar.expanded .collapsed-content { display: none; }

    .sidebar-header {
        flex-shrink: 0;
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 16px;
        padding-bottom: 12px;
    }
    .build-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 12px; }

    .sidebar-components {
        flex: 1;
        overflow-y: auto;
        margin-bottom: 16px;
        padding-right: 4px;
    }
    .component-item {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        padding: 8px;
        border-radius: 12px;
        background: #f8f9fa;
        transition: background 0.2s;
        cursor: pointer;
    }
    .component-item:hover { background: #e9ecef; }
    .component-icon { width: 40px; text-align: center; font-size: 1.5rem; color: #495057; }
    .component-details { flex: 1; }
    .component-name { font-weight: 500; font-size: 0.85rem; margin-bottom: 2px; }
    .component-price { font-size: 0.75rem; color: #1e2a3e; font-weight: 600; }
    .delete-component { color: #dc3545; background: none; border: none; padding: 0; font-size: 1.2rem; cursor: pointer; }
    .select-component-sidebar { border: 1px solid #ced4da; background: white; border-radius: 20px; padding: 2px 10px; font-size: 0.7rem; font-weight: 500; }
    .component-img { width: 35px; height: 35px; object-fit: contain; border-radius: 6px; }

    .sidebar-footer {
        flex-shrink: 0;
        border-top: 1px solid #dee2e6;
        padding-top: 12px;
    }
    .total-stats {
        background: #f1f3f5;
        border-radius: 12px;
        padding: 12px;
        margin: 8px 0;
    }
    .total-stats div { display: flex; justify-content: space-between; margin-bottom: 6px; }
    .btn-sidebar { border-radius: 30px; padding: 6px 12px; font-size: 0.8rem; width: 100%; margin-bottom: 8px; }

    .collapsed-header {
        text-align: center;
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #dee2e6;
    }
    .collapsed-stats {
        text-align: center;
        font-size: 0.85rem;
        font-weight: 600;
        background: #f1f3f5;
        border-radius: 16px;
        padding: 8px 12px;
        margin-bottom: 12px;
    }
    .collapsed-stats div {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        margin: 4px 0;
    }
    .collapsed-stats div span:first-child {
        font-weight: normal;
    }
    .collapsed-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        overflow-y: auto;
        flex: 1;
        padding: 4px 8px 8px 8px;
        margin-top: 8px;
    }
    .collapsed-category {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        cursor: pointer;
        padding: 8px 4px;
        border-radius: 16px;
        transition: background 0.2s;
    }
    .collapsed-category:hover { background: #f1f3f5; }
    .collapsed-category-icon {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 20px;
        margin-bottom: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }
    .collapsed-category-icon img {
        max-width: 68px;
        max-height: 68px;
        object-fit: contain;
    }
    .collapsed-category-icon i {
        font-size: 3rem;
        color: #495057;
    }
    .collapsed-category-label {
        font-size: 0.75rem;
        font-weight: 500;
        max-width: 100px;
    }

    body.sidebar-expanded .container { margin-right: 400px; transition: margin-right 0.3s; }
    body.sidebar-collapsed .container { margin-right: 200px; transition: margin-right 0.3s; }
    html, body { overflow-x: visible; }

    .total-stats div {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .value-group {
        display: inline-flex;
        gap: 4px;
    }
    .collapsed-stats div {
        font-weight: 700 !important;
    }
    .collapsed-stats div span:first-child {
        font-weight: 700 !important;
    }
    .collapsed-stats div span:last-child {
        font-weight: 700 !important;
    }
    .total-stats .value-group span:last-child {
        font-weight: 700 !important;
    }
</style>

<!-- HTML панели (как ранее, без изменений) -->
<div id="buildSidebar" class="build-sidebar collapsed">
    <div class="sidebar-toggle" id="sidebarToggle">
        <i class="bi bi-chevron-left"></i>
    </div>
    <div class="collapsed-content">
        <div class="collapsed-header">Конфигуратор ПК</div>
        <div class="collapsed-stats">
            <div><span id="collapsedPrice">0</span> ₽</div>
            <div><span id="collapsedWatts">0</span> Вт</div>
        </div>
        <div id="collapsedCategoriesGrid" class="collapsed-grid"></div>
    </div>
    <div class="expanded-content">
        <div class="sidebar-header">
            <div class="build-title">Конфигуратор ПК</div>
            <label class="form-label small">Название сборки</label>
            <input type="text" id="buildName" class="form-control form-control-sm" placeholder="Моя сборка" value="Моя сборка">
        </div>
        <div class="sidebar-components" id="componentsList"></div>
        <div class="sidebar-footer">
            <div class="total-stats">
                <div><span>Количество компонентов:</span> <strong id="selectedCount">0</strong></div>
                <div><span>Суммарная мощность:</span> <span class="value-group"><strong id="totalWatts">0</strong> <span>Вт</span></span></div>
                <div><span>Общая цена:</span> <strong id="totalPriceSidebar">0</strong></div>
            </div>
            <button class="btn btn-outline-secondary btn-sidebar" id="resetBuildBtn">Сбросить сборку</button>
            <button class="btn btn-dark btn-sidebar" id="saveBuildBtn">Сохранить сборку</button>
        </div>
    </div>
</div>

<script>
    // Все категории
    const allCategories = [
        { type: "Процессор", icon: "bi-cpu", defaultName: "Процессор" },
        { type: "Видеокарта", icon: "bi-gpu-card", defaultName: "Видеокарта" },
        { type: "Материнская плата", icon: "bi-motherboard", defaultName: "Материнская плата" },
        { type: "Оперативная память", icon: "bi-memory", defaultName: "Оперативная память" },
        { type: "Накопитель", icon: "bi-hdd-stack", defaultName: "Накопитель" },
        { type: "Блок питания", icon: "bi-plug", defaultName: "Блок питания" },
        { type: "Корпус", icon: "bi-pc-display", defaultName: "Корпус" },
        { type: "Система охлаждения", icon: "bi-fan", defaultName: "Система охлаждения" },
        { type: "Операционная система", icon: "bi-windows", defaultName: "ОС" },
        { type: "Монитор", icon: "bi-display", defaultName: "Монитор" },
        { type: "Источник бесперебойного питания", icon: "bi-battery-charging", defaultName: "UPS" },
        { type: "Клавиатура", icon: "bi-keyboard", defaultName: "Клавиатура" },
        { type: "Мышь", icon: "bi-mouse", defaultName: "Мышь" }
    ];

    let currentBuild = [];

    function loadBuildFromSession() {
        fetch('/PcBuilder/GetBuild')
            .then(response => response.json())
            .then(data => {
                if (data.success && data.build) {
                    currentBuild = data.build;
                    renderAll();
                } else {
                    renderAll();
                }
            });
    }

    function renderAll() {
        renderSidebarExpanded();
        renderSidebarCollapsed();
    }

    function renderSidebarExpanded() {
        let totalPrice = 0, totalWatts = 0;
        currentBuild.forEach(item => {
            totalPrice += item.price;
            if (item.tdp) totalWatts += item.tdp;
        });
        document.getElementById('totalPriceSidebar').innerText = totalPrice.toLocaleString() + ' ₽';
        document.getElementById('totalWatts').innerText = totalWatts;
        document.getElementById('selectedCount').innerText = currentBuild.length;

        let html = '';
        allCategories.forEach(cat => {
            if (cat.type === "Оперативная память") {
                // Все выбранные комплекты памяти
                const memoryItems = currentBuild.filter(c => c.type === cat.type);
                if (memoryItems.length > 0) {
                    memoryItems.forEach(selected => {
                        html += `
                            <div class="component-item" data-type="${cat.type}" data-id="${selected.id}">
                                <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                                <img src="${selected.imageUrl || '/images/placeholder.png'}" class="component-img">
                                <div class="component-details">
                                    <div class="component-name">${selected.name}${selected.moduleCount > 1 ? ' x' + selected.moduleCount : ''}</div>
                                    <div class="component-price">${selected.price.toLocaleString()} ₽</div>
                                </div>
                                <button class="delete-component" data-instance-id="${selected.instanceId}" title="Удалить"><i class="bi bi-trash"></i></button>
                            </div>
                        `;
                    });
                } else {
                    html += `
                        <div class="component-item" data-type="${cat.type}">
                            <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="component-details">
                                <div class="component-name">${cat.defaultName}</div>
                                <div class="component-price">—</div>
                            </div>
                            <button class="btn btn-sm select-component-sidebar" data-type="${cat.type}">Выбрать</button>
                        </div>
                    `;
                }
            } else if (cat.type === "Накопитель") {
                // Все выбранные накопители
                const storageItems = currentBuild.filter(c => c.type === cat.type);
                if (storageItems.length > 0) {
                    storageItems.forEach(selected => {
                        html += `
                            <div class="component-item" data-type="${cat.type}" data-id="${selected.id}">
                                <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                                <img src="${selected.imageUrl || '/images/placeholder.png'}" class="component-img">
                                <div class="component-details">
                                    <div class="component-name">${selected.name}</div>
                                    <div class="component-price">${selected.price.toLocaleString()} ₽</div>
                                </div>
                                <button class="delete-component" data-instance-id="${selected.instanceId}" title="Удалить"><i class="bi bi-trash"></i></button>
                            </div>
                        `;
                    });
                } else {
                    html += `
                        <div class="component-item" data-type="${cat.type}">
                            <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="component-details">
                                <div class="component-name">${cat.defaultName}</div>
                                <div class="component-price">—</div>
                            </div>
                            <button class="btn btn-sm select-component-sidebar" data-type="${cat.type}">Выбрать</button>
                        </div>
                    `;
                }
            } else if (cat.type === "Монитор") {
                // Все выбранные мониторы
                const monitorItems = currentBuild.filter(c => c.type === cat.type);
                if (monitorItems.length > 0) {
                    monitorItems.forEach(selected => {
                        html += `
                            <div class="component-item" data-type="${cat.type}" data-id="${selected.id}">
                                <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                                <img src="${selected.imageUrl || '/images/placeholder.png'}" class="component-img">
                                <div class="component-details">
                                    <div class="component-name">${selected.name}</div>
                                    <div class="component-price">${selected.price.toLocaleString()} ₽</div>
                                </div>
                                <button class="delete-component" data-instance-id="${selected.instanceId}" title="Удалить"><i class="bi bi-trash"></i></button>
                            </div>
                        `;
                    });
                } else {
                    html += `
                        <div class="component-item" data-type="${cat.type}">
                            <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="component-details">
                                <div class="component-name">${cat.defaultName}</div>
                                <div class="component-price">—</div>
                            </div>
                            <button class="btn btn-sm select-component-sidebar" data-type="${cat.type}">Выбрать</button>
                        </div>
                    `;
                }
            } else {
                // Остальные категории – только один компонент
                const selected = currentBuild.find(c => c.type === cat.type);
                if (selected) {
                    html += `
                        <div class="component-item" data-type="${cat.type}">
                            <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                            <img src="${selected.imageUrl || '/images/placeholder.png'}" class="component-img">
                            <div class="component-details">
                                <div class="component-name">${selected.name}</div>
                                <div class="component-price">${selected.price.toLocaleString()} ₽</div>
                            </div>
                            <button class="delete-component" data-instance-id="${selected.instanceId}" title="Удалить"><i class="bi bi-trash"></i></button>
                        </div>
                    `;
                } else {
                    html += `
                        <div class="component-item" data-type="${cat.type}">
                            <div class="component-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="component-details">
                                <div class="component-name">${cat.defaultName}</div>
                                <div class="component-price">—</div>
                            </div>
                            <button class="btn btn-sm select-component-sidebar" data-type="${cat.type}">Выбрать</button>
                        </div>
                    `;
                }
            }
        });
        document.getElementById('componentsList').innerHTML = html;

        // Обработчики удаления и выбора
        document.querySelectorAll('.delete-component').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const instanceId = btn.getAttribute('data-instance-id');
                removeFromBuild(instanceId);
            });
        });
        document.querySelectorAll('.select-component-sidebar').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const type = btn.getAttribute('data-type');
                if (type === "Процессор") window.location.href = '/Processors';
                else if (type === "Видеокарта") window.location.href = '/GraphicsCards';
                else if (type === "Материнская плата") window.location.href = '/Motherboards';
                else if (type === "Оперативная память") window.location.href = '/Memory';
                else if (type === "Накопитель") window.location.href = '/Storage';
                else if (type === "Блок питания") window.location.href = '/PowerSupplies';
                else if (type === "Корпус") window.location.href = '/Cases';
                else if (type === "Система охлаждения") window.location.href = '/Cooling';
                else if (type === "Операционная система") window.location.href = '/OperatingSystems';
                else if (type === "Монитор") window.location.href = '/Monitors';
                else if (type === "Источник бесперебойного питания") window.location.href = '/Ups';
                else if (type === "Клавиатура") window.location.href = '/Keyboards';
                else if (type === "Мышь") window.location.href = '/Mice';
                else alert(`Переход на страницу выбора ${type} (пока не реализовано)`);
            });
        });
        document.querySelectorAll('.component-item').forEach(row => {
            row.addEventListener('click', (e) => {
                if (e.target.closest('.delete-component')) return;
                if (e.target.closest('.select-component-sidebar')) return;
                const type = row.getAttribute('data-type');
                if (type === "Процессор") window.location.href = '/Processors';
                else if (type === "Видеокарта") window.location.href = '/GraphicsCards';
                else if (type === "Материнская плата") window.location.href = '/Motherboards';
                else if (type === "Оперативная память") window.location.href = '/Memory';
                else if (type === "Накопитель") window.location.href = '/Storage';
                else if (type === "Блок питания") window.location.href = '/PowerSupplies';
                else if (type === "Корпус") window.location.href = '/Cases';
                else if (type === "Система охлаждения") window.location.href = '/Cooling';
                else if (type === "Операционная система") window.location.href = '/OperatingSystems';
                else if (type === "Монитор") window.location.href = '/Monitors';
                else if (type === "Источник бесперебойного питания") window.location.href = '/Ups';
                else if (type === "Клавиатура") window.location.href = '/Keyboards';
                else if (type === "Мышь") window.location.href = '/Mice';
                else if (type) alert(`Переход на страницу ${type} (пока не реализовано)`);
            });
        });

        // Логика для RAM (добавление кнопки)
        const ramComponents = Array.from(document.querySelectorAll('.component-item[data-type="Оперативная память"]'))
            .filter(el => el.querySelector('.delete-component'));
        if (ramComponents.length > 0) {
            let ramModules = currentBuild.filter(c => c.type === "Оперативная память").reduce((sum, c) => sum + (c.moduleCount || 1), 0);
            let maxRamModules = 4;
            const motherboardComponent = currentBuild.find(c => c.type === "Материнская плата");
            if (motherboardComponent && motherboardComponent.memorySlots) {
                maxRamModules = motherboardComponent.memorySlots;
            }
            if (ramModules < maxRamModules) {
                const lastRam = ramComponents[ramComponents.length - 1];
                if (!document.getElementById('addMoreRamBtn')) {
                    const addButtonHtml = `
                        <div class="component-item" style="justify-content: center; background: transparent; cursor: default;">
                            <button class="btn btn-sm btn-outline-secondary" id="addMoreRamBtn">+ Добавить ещё комплект памяти</button>
                        </div>
                    `;
                    lastRam.insertAdjacentHTML('afterend', addButtonHtml);
                    document.getElementById('addMoreRamBtn').addEventListener('click', (e) => {
                        e.stopPropagation();
                        window.location.href = '/Memory';
                    });
                }
            }
        }

        // Логика для накопителей (добавление кнопки)
        const storageComponents = Array.from(document.querySelectorAll('.component-item[data-type="Накопитель"]'))
            .filter(el => el.querySelector('.delete-component'));
        if (storageComponents.length > 0) {
            const motherboardComponent = currentBuild.find(c => c.type === "Материнская плата");

            // Подсчитываем текущее использование
            const usedSata = currentBuild.filter(c => c.type === "Накопитель" &&
                (c.storageInterface === "SATA" || !c.storageInterface)).length;
            const usedM2 = currentBuild.filter(c => c.type === "Накопитель" &&
                c.storageInterface === "M.2").length;

            // Определяем лимиты
            let maxSata = 2;
            let maxM2 = 2;
            if (motherboardComponent) {
                maxSata = motherboardComponent.sataPorts || 2;
                maxM2 = motherboardComponent.m2Slots || 2;
            }

            // Есть ли свободные слоты?
            let canAdd = false;
            if (motherboardComponent) {
                canAdd = (usedSata < maxSata) || (usedM2 < maxM2);
            } else {
                const totalDrives = currentBuild.filter(c => c.type === "Накопитель").length;
                canAdd = totalDrives < 2;
            }

            if (canAdd) {
                // Удаляем старую кнопку, если она уже существует
                const oldBtn = document.getElementById('addMoreStorageBtn');
                if (oldBtn) {
                    oldBtn.parentElement.remove();
                }
                const lastStorage = storageComponents[storageComponents.length - 1];
                const addButtonHtml = `
                    <div class="component-item" style="justify-content: center; background: transparent; cursor: default;">
                        <button class="btn btn-sm btn-outline-secondary" id="addMoreStorageBtn">
                            + Добавить ещё накопитель
                        </button>
                    </div>
                `;
                lastStorage.insertAdjacentHTML('afterend', addButtonHtml);
                document.getElementById('addMoreStorageBtn').addEventListener('click', (e) => {
                    e.stopPropagation();
                    window.location.href = '/Storage';
                });
            }
        }

        // Логика для мониторов (добавление кнопки)
        const monitorComponents = Array.from(document.querySelectorAll('.component-item[data-type="Монитор"]'))
            .filter(el => el.querySelector('.delete-component'));
        if (monitorComponents.length > 0) {
            let currentMonitors = currentBuild.filter(c => c.type === "Монитор").length;
            const maxMonitors = 2;
            if (currentMonitors < maxMonitors) {
                const oldBtn = document.getElementById('addMoreMonitorBtn');
                if (oldBtn) oldBtn.parentElement.remove();
                const lastMonitor = monitorComponents[monitorComponents.length - 1];
                const addButtonHtml = `
                    <div class="component-item" style="justify-content: center; background: transparent; cursor: default;">
                        <button class="btn btn-sm btn-outline-secondary" id="addMoreMonitorBtn">
                            + Добавить ещё монитор
                        </button>
                    </div>
                `;
                lastMonitor.insertAdjacentHTML('afterend', addButtonHtml);
                document.getElementById('addMoreMonitorBtn').addEventListener('click', (e) => {
                    e.stopPropagation();
                    window.location.href = '/Monitors';
                });
            }
        }
    }

    function renderSidebarCollapsed() {
        let totalPrice = 0, totalWatts = 0;
        currentBuild.forEach(item => {
            totalPrice += item.price;
            if (item.tdp) totalWatts += item.tdp;
        });
        document.getElementById('collapsedWatts').innerText = totalWatts;
        document.getElementById('collapsedPrice').innerText = totalPrice.toLocaleString();

        let gridHtml = '';
        allCategories.forEach((cat, idx) => {
            if (cat.type === "Оперативная память") {
                const items = currentBuild.filter(c => c.type === cat.type);
                if (items.length > 0) {
                    items.forEach((item, itemIdx) => {
                        const iconHtml = item.imageUrl ? `<img src="${item.imageUrl}" alt="${item.name}">` : `<i class="bi ${cat.icon}"></i>`;
                        const label = `${item.name}${item.moduleCount > 1 ? ' x' + item.moduleCount : ''}`;
                        gridHtml += `
                            <div class="collapsed-category" data-type="${cat.type}" data-id="${item.id}" data-index="mem_${itemIdx}">
                                <div class="collapsed-category-icon">${iconHtml}</div>
                                <div class="collapsed-category-label">${label.length > 20 ? label.substring(0,18)+'…' : label}</div>
                            </div>
                        `;
                    });
                } else {
                    gridHtml += `
                        <div class="collapsed-category" data-type="${cat.type}" data-index="empty">
                            <div class="collapsed-category-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="collapsed-category-label">${cat.defaultName}</div>
                        </div>
                    `;
                }
            } else if (cat.type === "Накопитель") {
                const items = currentBuild.filter(c => c.type === cat.type);
                if (items.length > 0) {
                    items.forEach((item, itemIdx) => {
                        const iconHtml = item.imageUrl ? `<img src="${item.imageUrl}" alt="${item.name}">` : `<i class="bi ${cat.icon}"></i>`;
                        const label = item.name;
                        gridHtml += `
                            <div class="collapsed-category" data-type="${cat.type}" data-id="${item.id}" data-index="storage_${itemIdx}">
                                <div class="collapsed-category-icon">${iconHtml}</div>
                                <div class="collapsed-category-label">${label.length > 20 ? label.substring(0,18)+'…' : label}</div>
                            </div>
                        `;
                    });
                } else {
                    gridHtml += `
                        <div class="collapsed-category" data-type="${cat.type}" data-index="empty">
                            <div class="collapsed-category-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="collapsed-category-label">${cat.defaultName}</div>
                        </div>
                    `;
                }
            } else if (cat.type === "Монитор") {
                const items = currentBuild.filter(c => c.type === cat.type);
                if (items.length > 0) {
                    items.forEach((item, itemIdx) => {
                        const iconHtml = item.imageUrl ? `<img src="${item.imageUrl}" alt="${item.name}">` : `<i class="bi ${cat.icon}"></i>`;
                        const label = item.name;
                        gridHtml += `
                            <div class="collapsed-category" data-type="${cat.type}" data-id="${item.id}" data-index="monitor_${itemIdx}">
                                <div class="collapsed-category-icon">${iconHtml}</div>
                                <div class="collapsed-category-label">${label.length > 20 ? label.substring(0,18)+'…' : label}</div>
                            </div>
                        `;
                    });
                } else {
                    gridHtml += `
                        <div class="collapsed-category" data-type="${cat.type}" data-index="empty">
                            <div class="collapsed-category-icon"><i class="bi ${cat.icon}"></i></div>
                            <div class="collapsed-category-label">${cat.defaultName}</div>
                        </div>
                    `;
                }
            } else {
                const selected = currentBuild.find(c => c.type === cat.type);
                const iconHtml = (selected && selected.imageUrl) ? `<img src="${selected.imageUrl}" alt="${selected.name}">` : `<i class="bi ${cat.icon}"></i>`;
                const label = selected ? selected.name : cat.defaultName;
                gridHtml += `
                    <div class="collapsed-category" data-type="${cat.type}" data-index="${idx}">
                        <div class="collapsed-category-icon">${iconHtml}</div>
                        <div class="collapsed-category-label">${label.length > 20 ? label.substring(0,18)+'…' : label}</div>
                    </div>
                `;
            }
        });
        document.getElementById('collapsedCategoriesGrid').innerHTML = gridHtml;

        document.querySelectorAll('.collapsed-category').forEach(el => {
            el.addEventListener('click', () => {
                const type = el.getAttribute('data-type');
                if (type === "Процессор") window.location.href = '/Processors';
                else if (type === "Видеокарта") window.location.href = '/GraphicsCards';
                else if (type === "Материнская плата") window.location.href = '/Motherboards';
                else if (type === "Оперативная память") window.location.href = '/Memory';
                else if (type === "Накопитель") window.location.href = '/Storage';
                else if (type === "Блок питания") window.location.href = '/PowerSupplies';
                else if (type === "Корпус") window.location.href = '/Cases';
                else if (type === "Система охлаждения") window.location.href = '/Cooling';
                else if (type === "Операционная система") window.location.href = '/OperatingSystems';
                else if (type === "Монитор") window.location.href = '/Monitors';
                else if (type === "Источник бесперебойного питания") window.location.href = '/Ups';
                else if (type === "Клавиатура") window.location.href = '/Keyboards';
                else if (type === "Мышь") window.location.href = '/Mice';
                else alert(`Переход на страницу выбора ${type} (пока не реализовано)`);
            });
        });
    }

    function addToBuild(component) {
        // Генерируем уникальный идентификатор для этого экземпляра
        component.instanceId = crypto.randomUUID ? crypto.randomUUID() : (Date.now() + '-' + Math.random());
    
        fetch('/PcBuilder/AddComponent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(component)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                currentBuild = data.build;
                renderAll();
            } else {
                alert(data.error || 'Ошибка добавления');
            }
        });
    }

    function removeFromBuild(instanceId) {
        fetch('/PcBuilder/RemoveComponent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ instanceId: instanceId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                currentBuild = data.build;
                renderAll();
            }
        });
    }

    // Управление сворачиванием
    const sidebar = document.getElementById('buildSidebar');
    const toggleBtn = document.getElementById('sidebarToggle');
    const body = document.body;
    if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
            if (sidebar.classList.contains('collapsed')) {
                sidebar.classList.remove('collapsed');
                sidebar.classList.add('expanded');
                body.classList.remove('sidebar-collapsed');
                body.classList.add('sidebar-expanded');
                toggleBtn.innerHTML = '<i class="bi bi-chevron-right"></i>';
            } else {
                sidebar.classList.remove('expanded');
                sidebar.classList.add('collapsed');
                body.classList.remove('sidebar-expanded');
                body.classList.add('sidebar-collapsed');
                toggleBtn.innerHTML = '<i class="bi bi-chevron-left"></i>';
            }
        });
        body.classList.add('sidebar-collapsed');
    }

    // Сброс сборки
    function resetBuild() {
        fetch('/PcBuilder/ClearBuild', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                currentBuild = [];
                renderAll();
            } else {
                alert('Ошибка сброса');
            }
        });
    }

    function saveBuild() {
        const buildName = document.getElementById('buildName')?.value.trim() || 'Моя сборка';
        fetch('/PcBuilder/SaveBuild', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: buildName, components: currentBuild })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Сборка сохранена!');
            } else {
                alert('Ошибка сохранения: ' + (data.error || 'неизвестная ошибка'));
            }
        });
    }

    document.getElementById('resetBuildBtn')?.addEventListener('click', resetBuild);
    document.getElementById('saveBuildBtn')?.addEventListener('click', saveBuild);

    loadBuildFromSession();
</script>