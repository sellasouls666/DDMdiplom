@model IEnumerable<DDMdiplom.Models.Case>

@{
    ViewData["Title"] = "Корпуса";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ========== Карточки корпусов ========== */
        .case-card {
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
        }
        .case-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        }
        .card-img-container {
            height: 220px;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }
        .card-img-top {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
        }
        .case-card:hover .card-img-top {
            transform: scale(1.02);
        }
        .card-body {
            padding: 12px 12px 4px 12px;
        }
        .card-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.3;
        }
        .spec-badge {
            background: #f1f3f5;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 0.75rem;
            color: #495057;
            display: inline-block;
            white-space: nowrap;
        }
        .card-specs {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 10px;
        }
        .price {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e2a3e;
            white-space: nowrap;
        }
        .btn-outline-add {
            border-radius: 40px;
            padding: 5px 14px;
            font-size: 0.8rem;
            white-space: nowrap;
        }
        .card-footer {
            padding: 0 12px 14px 12px;
            background: transparent;
            border: none;
        }
        .card-footer .d-flex {
            gap: 8px;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }
        .case-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 24px;
        }
        .case-grid .col {
            flex: 0 0 280px;
            max-width: 280px;
        }

        /* Модальное окно */
        .modal-specs-table { width: 100%; margin-bottom: 20px; }
        .modal-specs-table td { padding: 8px 12px; vertical-align: top; }
        .modal-specs-table td:first-child { font-weight: 600; width: 40%; background-color: #f8f9fa; }
        .price-large { font-size: 1.5rem; font-weight: 700; color: #1e2a3e; }
        .btn-select-sm { border-radius: 40px; padding: 4px 20px; font-size: 0.85rem; }
    </style>
}

<div class="container">
    <h1 class="mb-3">Корпуса</h1>
    
    <!-- Переключатель совместимости -->
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="compatibilitySwitch" checked>
        <label class="form-check-label" for="compatibilitySwitch">Проверка совместимости</label>
    </div>

    <div class="case-grid">
        @foreach (var item in Model)
        {
            var imageUrl = !string.IsNullOrEmpty(item.ImageUrl) ? item.ImageUrl : "/images/placeholder.png";
            <div class="col">
                <div class="card case-card h-100"
                     data-id="@item.Id"
                     data-max-gpu-length="@item.MaxGpuLength"
                     data-motherboard-compatibility="@item.MotherboardCompatibility"
                     data-max-psu-length="@item.MaxPsuLength">
                    <div class="card-img-container">
                        <img src="@imageUrl" class="card-img-top" alt="@item.Model">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@item.Brand @item.Model</h5>
                        <div class="card-specs">
                            @if (!string.IsNullOrEmpty(item.Type))
                            {
                                <span class="spec-badge"><i class="bi bi-pc-display"></i> @item.Type</span>
                            }
                            @if (!string.IsNullOrEmpty(item.Color))
                            {
                                <span class="spec-badge"><i class="bi bi-palette"></i> @item.Color</span>
                            }
                            @if (!string.IsNullOrEmpty(item.CaseMaterial))
                            {
                                <span class="spec-badge"><i class="bi bi-boxes"></i> @item.CaseMaterial</span>
                            }
                            @if (item.MaxGpuLength.HasValue)
                            {
                                <span class="spec-badge"><i class="bi bi-gpu-card"></i> GPU до @item.MaxGpuLength мм</span>
                            }
                            @if (!string.IsNullOrEmpty(item.LED))
                            {
                                <span class="spec-badge"><i class="bi bi-lightbulb"></i> @item.LED</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price">@string.Format("{0:N0}", item.Price) ₽</span>
                            <button class="btn btn-outline-dark btn-outline-add select-component"
                                    data-id="@item.Id"
                                    data-name="@item.Brand @item.Model"
                                    data-price="@item.Price"
                                    data-tdp="0"
                                    data-image="@imageUrl"
                                    data-type="Корпус">
                                <i class="bi bi-plus-lg"></i> Выбрать
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальное окно для деталей корпуса -->
<div class="modal fade" id="caseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div id="modalContent">
                    <div class="text-center my-3"><div class="spinner-border" role="status"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BuildSidebar")

@section Scripts {
    <script>
        // Обработчики для кнопок "Выбрать"
        document.querySelectorAll('.select-component').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const component = {
                    id: parseInt(this.dataset.id),
                    name: this.dataset.name,
                    price: parseFloat(this.dataset.price),
                    type: this.dataset.type,
                    tdp: 0,
                    imageUrl: this.dataset.image
                };
                if (typeof addToBuild === 'function') {
                    addToBuild(component);
                } else {
                    console.error('addToBuild not defined');
                }
            });
        });

        // Открытие модального окна по клику на карточку
        document.querySelectorAll('.case-card').forEach(card => {
            card.addEventListener('click', async function(e) {
                if (e.target.closest('.select-component')) return;
                const caseId = this.getAttribute('data-id');
                const contentDiv = document.getElementById('modalContent');
                contentDiv.innerHTML = '<div class="text-center my-3"><div class="spinner-border" role="status"></div></div>';
                try {
                    const response = await fetch(`/Cases/GetCase/${caseId}`);
                    const item = await response.json();

                    // Основная информация
                    let part1Rows = '';
                    if (item.brand) part1Rows += `<tr><td>Бренд</td><td>${item.brand}</td></tr>`;
                    if (item.series) part1Rows += `<tr><td>Серия</td><td>${item.series}</td></tr>`;
                    if (item.model) part1Rows += `<tr><td>Модель</td><td>${item.model}</td></tr>`;
                    if (item.type) part1Rows += `<tr><td>Тип</td><td>${item.type}</td></tr>`;
                    if (item.color) part1Rows += `<tr><td>Цвет</td><td>${item.color}</td></tr>`;
                    if (item.caseMaterial) part1Rows += `<tr><td>Материал</td><td>${item.caseMaterial}</td></tr>`;
                    if (item.motherboardCompatibility) part1Rows += `<tr><td>Совместимость с материнскими платами</td><td>${item.motherboardCompatibility}</td></tr>`;
                    if (item.sidePanel) part1Rows += `<tr><td>Боковая панель</td><td>${item.sidePanel}</td></tr>`;
                    if (item.dimensions) part1Rows += `<tr><td>Габариты (Д x Ш x В)</td><td>${item.dimensions}</td></tr>`;
                    if (item.weight) part1Rows += `<tr><td>Вес</td><td>${item.weight}</td></tr>`;
                    const part1 = part1Rows ? `<div class="mb-4"><h6 class="mb-2">Основная информация</h6><table class="modal-specs-table">${part1Rows}</table></div>` : '';

                    // Детальные характеристики
                    let part2Rows = '';
                    if (item.internal35Bays) part2Rows += `<tr><td>Внутренние отсеки 3.5"</td><td>${item.internal35Bays}</td></tr>`;
                    if (item.internal25Bays) part2Rows += `<tr><td>Внутренние отсеки 2.5"</td><td>${item.internal25Bays}</td></tr>`;
                    if (item.expansionSlots) part2Rows += `<tr><td>Слоты расширения</td><td>${item.expansionSlots}</td></tr>`;
                    if (item.verticalGpuSupport) part2Rows += `<tr><td>Поддержка вертикальной GPU</td><td>${item.verticalGpuSupport}</td></tr>`;
                    if (item.frontPorts) part2Rows += `<tr><td>Передние порты</td><td>${item.frontPorts}</td></tr>`;
                    if (item.fanOptions) part2Rows += `<tr><td>Варианты вентиляторов</td><td>${item.fanOptions}</td></tr>`;
                    if (item.preInstalledFans) part2Rows += `<tr><td>Предустановленные вентиляторы</td><td>${item.preInstalledFans}</td></tr>`;
                    if (item.radiatorOptions) part2Rows += `<tr><td>Варианты радиаторов</td><td>${item.radiatorOptions}</td></tr>`;
                    if (item.maxGpuLength) part2Rows += `<tr><td>Макс. длина GPU (мм)</td><td>${item.maxGpuLength}</td></tr>`;
                    if (item.maxCpuCoolerHeight) part2Rows += `<tr><td>Макс. высота кулера CPU (мм)</td><td>${item.maxCpuCoolerHeight}</td></tr>`;
                    if (item.maxPsuLength) part2Rows += `<tr><td>Макс. длина БП (мм)</td><td>${item.maxPsuLength}</td></tr>`;
                    if (item.packageContent) part2Rows += `<tr><td>Комплектация</td><td>${item.packageContent}</td></tr>`;
                    const part2 = part2Rows ? `<div><h6 class="mb-2">Детальные характеристики</h6><table class="modal-specs-table">${part2Rows}</table></div>` : '';

                    const title = `${item.brand} ${item.model}`;
                    const imageUrl = item.imageUrl || '/images/placeholder.png';
                    const priceHtml = `<div class="price-large mb-2">${item.price.toLocaleString()} ₽</div>`;
                    const selectBtn = `<button class="btn btn-outline-dark btn-select-sm select-from-modal" data-id="${item.id}" data-name="${title}" data-price="${item.price}" data-tdp="0" data-image="${imageUrl}" data-type="Корпус"><i class="bi bi-plus-lg"></i> Выбрать</button>`;

                    contentDiv.innerHTML = `
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="${imageUrl}" alt="${title}" style="width: 50px; height: 50px; object-fit: contain;">
                                <h5 class="mb-0">${title}</h5>
                            </div>
                            <div class="text-end">
                                ${priceHtml}
                                ${selectBtn}
                            </div>
                        </div>
                        ${part1}
                        ${part2}
                    `;

                    document.querySelector('.select-from-modal').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const component = {
                            id: parseInt(this.dataset.id),
                            name: this.dataset.name,
                            price: parseFloat(this.dataset.price),
                            type: this.dataset.type,
                            tdp: 0,
                            imageUrl: this.dataset.image
                        };
                        if (typeof addToBuild === 'function') addToBuild(component);
                    });

                    const modal = new bootstrap.Modal(document.getElementById('caseModal'));
                    modal.show();
                } catch (error) {
                    console.error(error);
                    contentDiv.innerHTML = '<div class="alert alert-danger">Ошибка загрузки данных</div>';
                }
            });
        });

        // ========== ФИЛЬТР СОВМЕСТИМОСТИ КОРПУСОВ ==========
        const compatibilitySwitch = document.getElementById('compatibilitySwitch');
        const caseCards = document.querySelectorAll('.case-card');

        async function applyCaseFilter() {
            if (!compatibilitySwitch.checked) {
                caseCards.forEach(card => card.closest('.col').style.display = '');
                return;
            }
            try {
                const response = await fetch('/PcBuilder/GetBuild');
                const data = await response.json();
                const build = data.success ? data.build : [];

                const gpu = build.find(c => c.type === "Видеокарта");
                const mb = build.find(c => c.type === "Материнская плата");
                const psu = build.find(c => c.type === "Блок питания");

                const requiredGpuLen = gpu?.gpuLength;
                const requiredMbForm = mb?.mbFormFactor?.trim().toLowerCase();
                const requiredPsuLen = psu?.psuLength;

                caseCards.forEach(card => {
                    const col = card.closest('.col');
                    const maxGpu = parseInt(card.dataset.maxGpuLength) || 0;
                    const maxPsu = parseInt(card.dataset.maxPsuLength) || 0;
                    const mbCompat = card.dataset.motherboardCompatibility?.toLowerCase() || '';

                    let visible = true;
                    if (requiredGpuLen && maxGpu > 0 && maxGpu < requiredGpuLen) visible = false;
                    if (visible && requiredMbForm && mbCompat && !mbCompat.includes(requiredMbForm)) visible = false;
                    if (visible && requiredPsuLen && maxPsu > 0 && maxPsu < requiredPsuLen) visible = false;

                    col.style.display = visible ? '' : 'none';
                });
            } catch (err) {
                console.error('Ошибка фильтра корпусов:', err);
                caseCards.forEach(card => card.closest('.col').style.display = '');
            }
        }

        compatibilitySwitch.addEventListener('change', applyCaseFilter);
        applyCaseFilter();
    </script>
}