@using DDMdiplom.ViewModels
@model List<CartItemViewModel>
@{
    ViewData["Title"] = "Корзина";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .cart-item {
        transition: box-shadow 0.2s;
    }

        .cart-item:hover {
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

    .preview-img {
        width: 70px;
        height: 70px;
        object-fit: contain;
    }

    .preview-name {
        font-size: 0.75rem;
        line-height: 1.2;
        max-width: 80px;
    }
</style>

<div class="container mt-4">
    <h2 class="mb-4">Корзина</h2>

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-5">
            <i class="bi bi-cart" style="font-size: 4rem;"></i>
            <p class="mt-3">Ваша корзина пуста</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="card cart-item border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title">@item.Name</h5>
                                <div class="d-flex gap-3 mt-2 flex-wrap">
                                    @foreach (var prev in item.Previews)
                                    {
                                        <div class="text-center flex-shrink-0">
                                            <img src="@prev.ImageUrl" alt="@prev.Name" class="preview-img rounded-2" />
                                            <div class="preview-name text-muted mt-1" title="@prev.Name">@prev.Name</div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="text-end ms-4">
                                <div class="d-flex align-items-center justify-content-end gap-2 mb-2">
                                    @if (item.Quantity > 1)
                                    {
                                        <form asp-action="DecreaseQuantity" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button class="btn btn-outline-secondary btn-sm rounded-pill px-2">-</button>
                                        </form>
                                    }
                                    <span class="fw-bold">@item.Quantity</span>
                                    @if (item.Quantity < 10)
                                    {
                                        <form asp-action="IncreaseQuantity" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button class="btn btn-outline-secondary btn-sm rounded-pill px-2">+</button>
                                        </form>
                                    }
                                </div>
                                <div class="text-muted small">Компонентов</div>
                                <div class="fw-bold">@item.ComponentCount</div>
                                <div class="text-muted small mt-2">Цена</div>
                                <div class="fw-bold">@((item.TotalPrice * item.Quantity).ToString("N0")) ₽</div>
                                <form asp-action="Remove" asp-route-id="@item.Id" method="post" class="mt-2">
                                    <button class="btn btn-outline-danger btn-sm rounded-pill">
                                        <i class="bi bi-trash"></i> Удалить
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Общая цена корзины -->
        <div class="d-flex justify-content-end mt-4">
            <div class="bg-light rounded-4 p-3">
                <span class="text-muted me-3">Общая стоимость:</span>
                <strong class="fs-5">@Model.Sum(i => i.TotalPrice * i.Quantity).ToString("N0") ₽</strong>
            </div>
        </div>

        <form asp-action="Clear" method="post" class="mt-3">
            <button class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-cart-x"></i> Очистить корзину
            </button>
        </form>
    }
</div>