@using DDMdiplom.ViewModels
@model List<CartItemViewModel>
@{
    ViewData["Title"] = "Корзина";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --black: #111;
        --white: #fff;
        --gray-50: #fafafa;
        --gray-100: #f4f4f5;
        --gray-200: #e4e4e7;
        --gray-300: #d4d4d8;
        --gray-500: #71717a;
        --gray-700: #3f3f46;
        --gray-900: #18181b;
        --radius: 20px;
        --radius-sm: 12px;
        --transition: 0.2s ease;
    }

    body {
        background: var(--gray-50);
    }

    .cart-header {
        margin-bottom: 2rem;
        border-bottom: 2px solid var(--gray-200);
        padding-bottom: 0.75rem;
    }

        .cart-header h2 {
            font-weight: 700;
            letter-spacing: -0.3px;
            color: var(--black);
        }

    /* Карточка товара */
    .cart-item-card {
        background: var(--white);
        border: 1px solid var(--gray-200);
        border-radius: var(--radius);
        transition: all var(--transition);
        overflow: hidden;
    }

        .cart-item-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.05);
            border-color: var(--gray-300);
        }

    .cart-item-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem;
    }

    /* Левая часть – информация о сборке */
    .item-info {
        flex: 2;
        min-width: 200px;
    }

    .item-name {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--black);
        margin-bottom: 0.75rem;
    }

    .previews-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 0.5rem;
        max-height: 180px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .preview-item {
        text-align: center;
        width: 85px;
        flex-shrink: 0;
    }

    .preview-img {
        width: 60px;
        height: 60px;
        object-fit: contain;
        background: var(--gray-100);
        border-radius: var(--radius-sm);
        padding: 6px;
        transition: transform var(--transition);
    }

    .preview-item:hover .preview-img {
        transform: scale(1.02);
    }

    .preview-name {
        font-size: 0.7rem;
        color: var(--gray-500);
        margin-top: 0.3rem;
        line-height: 1.3;
        word-break: break-word;
        max-width: 85px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Правая часть – управление количеством и ценой */
    .item-actions {
        flex: 1;
        min-width: 160px;
        text-align: right;
    }

    .quantity-control {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .quantity-btn {
        background: transparent;
        border: 1px solid var(--gray-200);
        border-radius: 30px;
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        transition: all var(--transition);
        color: var(--gray-700);
    }

        .quantity-btn:hover {
            background: var(--gray-100);
            border-color: var(--gray-300);
        }

    .quantity-number {
        font-weight: 600;
        font-size: 1rem;
        min-width: 24px;
        text-align: center;
    }

    .price-block {
        margin: 0.5rem 0;
    }

    .price-label {
        font-size: 0.75rem;
        color: var(--gray-500);
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .price-value {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--black);
    }

    .remove-btn {
        background: transparent;
        border: 1px solid var(--gray-200);
        border-radius: 30px;
        padding: 0.3rem 1rem;
        font-size: 0.8rem;
        transition: all var(--transition);
        color: var(--gray-700);
    }

        .remove-btn:hover {
            background: #fee2e2;
            border-color: #fecaca;
            color: #b91c1c;
        }

    /* Итоговая панель */
    .total-panel {
        background: var(--white);
        border: 1px solid var(--gray-200);
        border-radius: var(--radius);
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2rem;
    }

    .total-label {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--gray-500);
        letter-spacing: 0.3px;
    }

    .total-amount {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--black);
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-outline-clear {
        background: transparent;
        border: 1px solid var(--gray-300);
        border-radius: 40px;
        padding: 0.6rem 1.5rem;
        font-weight: 500;
        transition: all var(--transition);
        color: var(--gray-700);
    }

        .btn-outline-clear:hover {
            background: var(--gray-100);
            border-color: var(--gray-400);
        }

    .btn-checkout {
        background: var(--black);
        color: var(--white);
        border: none;
        border-radius: 40px;
        padding: 0.7rem 2rem;
        font-weight: 600;
        transition: all var(--transition);
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

        .btn-checkout:hover {
            background: var(--gray-900);
            transform: translateY(-1px);
            box-shadow: 0 8px 20px -6px rgba(0,0,0,0.15);
        }

    .empty-cart {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--gray-200);
    }

    .empty-icon {
        font-size: 4rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
    }

    /* кастомный скролл для списка компонентов */
    .previews-list::-webkit-scrollbar {
        width: 4px;
    }

    .previews-list::-webkit-scrollbar-track {
        background: var(--gray-100);
        border-radius: 4px;
    }

    .previews-list::-webkit-scrollbar-thumb {
        background: var(--gray-300);
        border-radius: 4px;
    }

    @@media (max-width: 768px) {
        .cart-item-inner {
            flex-direction: column;
            align-items: flex-start;
        }

        .item-actions {
            width: 100%;
            text-align: left;
        }

        .quantity-control {
            justify-content: flex-start;
        }

        .total-panel {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
        }

        .action-buttons {
            justify-content: center;
        }
    }
</style>

<div class="container py-4">
    <div class="cart-header">
        <h2><i class="bi bi-cart me-2"></i>Корзина</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-cart">
            <div class="empty-icon"><i class="bi bi-cart"></i></div>
            <h5 class="fw-bold">Ваша корзина пуста</h5>
            <p class="text-muted">Добавьте конфигурацию или товары в корзину, чтобы оформить заказ</p>
            <a href="/PcBuilder/ClearAndGoToProcessors" class="btn btn-dark rounded-pill px-4 mt-2">Перейти в конфигуратор</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="cart-item-card">
                        <div class="cart-item-inner">
                            <div class="item-info">
                                <div class="item-name">@item.Name</div>
                                <div class="previews-list">
                                    @foreach (var prev in item.Previews)
                                    {
                                        <div class="preview-item" title="@prev.Name">
                                            <img src="@prev.ImageUrl" alt="@prev.Name" class="preview-img" />
                                            <div class="preview-name">@prev.Name</div>
                                        </div>
                                    }
                                </div>
                                <div class="text-muted small mt-2">
                                    <i class="bi bi-grid-3x3-gap-fill me-1"></i> @item.ComponentCount компонентов
                                </div>
                            </div>

                            <div class="item-actions">
                                <div class="quantity-control">
                                    @if (item.Quantity > 1)
                                    {
                                        <form asp-action="DecreaseQuantity" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button class="quantity-btn">−</button>
                                        </form>
                                    }
                                    <span class="quantity-number">@item.Quantity</span>
                                    @if (item.Quantity < 10)
                                    {
                                        <form asp-action="IncreaseQuantity" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button class="quantity-btn">+</button>
                                        </form>
                                    }
                                </div>
                                <div class="price-block">
                                    <div class="price-label">Цена за сборку</div>
                                    <div class="price-value">@item.TotalPrice.ToString("N0") ₽</div>
                                </div>
                                <div class="price-block mt-2">
                                    <div class="price-label">Итого</div>
                                    <div class="price-value">@((item.TotalPrice * item.Quantity).ToString("N0")) ₽</div>
                                </div>
                                <form asp-action="Remove" asp-route-id="@item.Id" method="post" class="mt-3">
                                    <button class="remove-btn">
                                        <i class="bi bi-trash"></i> Удалить
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="total-panel">
            <div>
                <span class="total-label">Общая стоимость</span>
                <div class="total-amount">@Model.Sum(i => i.TotalPrice * i.Quantity).ToString("N0") ₽</div>
            </div>
            <div class="action-buttons">
                <form asp-action="Clear" method="post">
                    <button class="btn-outline-clear">
                        <i class="bi bi-cart-x"></i> Очистить корзину
                    </button>
                </form>
                <a asp-controller="Orders" asp-action="Checkout" class="btn-checkout">
                    <i class="bi bi-credit-card me-2"></i> Оформить заказ
                </a>
            </div>
        </div>
    }
</div>